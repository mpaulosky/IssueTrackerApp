@using Web.Auth
@implements IDisposable
@inject NavigationManager Navigation

<header role="banner" class="bg-primary-400 dark:bg-primary-900">
<nav aria-label="Main navigation" class="active-theme hidden md:flex">

	<a href="/" class="text-xl whitespace-nowrap">@SiteName</a>

	@* Desktop navigation — horizontal bar, hidden on mobile *@
	<AuthorizeView>
		<Authorized>
			<a href="/" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Home</a>
			<a href="/dashboard" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Dashboard</a>
			<a href="/issues" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Issues</a>
			<a href="/issues/create" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Create</a>
			<a href="/profile">Hey @context.User.Identity?.Name!</a>
		</Authorized>
	</AuthorizeView>

	<AuthorizeView Policy="@AuthorizationPolicies.AdminPolicy">
		<Authorized>
		<div class="h-6 w-px bg-neutral-300 dark:bg-neutral-600 mx-2" aria-hidden="true"></div>
		<a href="/admin" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Admin</a>
		<a href="/admin/categories" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Categories</a>
		<a href="/admin/statuses" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Statuses</a>
		<a href="/admin/analytics" class="px-3 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Analytics</a>
		</Authorized>
	</AuthorizeView>

	<div class="flex items-center gap-2">
		<LoginDisplay/>
		<ThemeBrightnessToggleComponent/>
		<ThemeColorDropdownComponent/>
		<AuthorizeView>
			<Authorized>
				<SignalRConnection/>
			</Authorized>
		</AuthorizeView>
	</div>
</nav>
</header>

@code {
	private bool _mobileMenuOpen;

	[CascadingParameter] private Task<AuthenticationState>? AuthenticationState { get; set; }

	private const string SiteName = "IssueTracker App";

	protected override void OnInitialized()
	{
		Navigation.LocationChanged += OnLocationChanged;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		if (_mobileMenuOpen)
		{
			_mobileMenuOpen = false;
			StateHasChanged();
		}
	}

	public void Dispose()
	{
		Navigation.LocationChanged -= OnLocationChanged;
	}

}
