<footer class="border-t border-[var(--border-color)] bg-[var(--bg-surface)] py-4" role="contentinfo">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-[var(--text-muted)]">

		<span>&copy; @DateTime.Now.Year IssueManager &mdash; Built with .NET 10 &amp; Blazor</span>

		<div class="flex items-center gap-4 font-mono text-xs">
			<a href="@_releaseUrl"
			   target="_blank"
			   rel="noopener noreferrer"
			   class="hover:text-[var(--color-primary)] transition-colors"
			   title="View @BuildInfo.Version on GitHub">
				@BuildInfo.Version
			</a>
			<a href="@_commitUrl"
			   target="_blank"
			   rel="noopener noreferrer"
			   class="hover:text-[var(--color-primary)] transition-colors"
			   title="View commit @BuildInfo.Commit on GitHub">
				@BuildInfo.Commit
			</a>
		</div>

	</div>
</footer>

@code {
	private const string RepoBase = "https://github.com/mpaulosky/IssueManager";

	private string _releaseUrl = $"{RepoBase}/releases";
	private string _commitUrl = $"{RepoBase}/commits";

	/// <summary>
	/// Resolves GitHub URLs from the build-time <see cref="BuildInfo"/> constants.
	/// </summary>
	protected override void OnInitialized()
	{
		_releaseUrl = IsKnown(BuildInfo.Version)
			? $"{RepoBase}/releases/tag/{BuildInfo.Version}"
			: $"{RepoBase}/releases";

		_commitUrl = IsKnown(BuildInfo.Commit)
			? $"{RepoBase}/commit/{BuildInfo.Commit}"
			: $"{RepoBase}/commits";
	}

	private static bool IsKnown(string value) =>
		!string.IsNullOrWhiteSpace(value) && value != "unknown" && value != "v0.0.0";
}
