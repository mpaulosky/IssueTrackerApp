@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<AuthorizeView>
	<Authorized>
		<div class="user-info">
			<span class="user-name">Hello, @context.User.Identity?.Name!</span>
			<a href="/account/logout" class="btn-logout">Log out</a>
		</div>
	</Authorized>
	<NotAuthorized>
		<a href="/account/login?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" class="btn-login">Log in</a>
	</NotAuthorized>
</AuthorizeView>
