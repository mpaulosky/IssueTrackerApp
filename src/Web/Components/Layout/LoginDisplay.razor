@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<AuthorizeView>
	<Authorized>
		<div class="flex items-center gap-4">
			<span class="text-sm text-gray-700">Hello, @context.User.Identity?.Name!</span>
			<form method="post" action="/account/logout" class="inline">
				<AntiforgeryToken />
				<button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors">Log out</button>
			</form>
		</div>
	</Authorized>
	<NotAuthorized>
		<a href="/account/login?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">Log in</a>
	</NotAuthorized>
</AuthorizeView>
