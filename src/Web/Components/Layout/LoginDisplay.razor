@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<AuthorizeView>
	<Authorized>
		<div class="flex items-center gap-4">
			<span class="text-sm text-gray-700">Hello, @context.User.Identity?.Name!</span>
			<form method="post" action="/account/logout" data-enhance="false" class="inline">
				<AntiforgeryToken />
				<button type="submit" class="btn-danger transition-colors">Log out</button>
			</form>
		</div>
	</Authorized>
	<NotAuthorized>
		<a href="/account/login?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" class="btn-primary transition-colors">Log in</a>
	</NotAuthorized>
</AuthorizeView>
