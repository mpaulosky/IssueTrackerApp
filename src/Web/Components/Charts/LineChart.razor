@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div class="relative w-full h-full">
	@if (IsLoading)
	{
		<div class="flex items-center justify-center h-64">
			<div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary-600"></div>
		</div>
	}
	else
	{
		<canvas id="@ChartId"></canvas>
	}
</div>

@code {
	/// <summary>
	/// Unique identifier for the chart canvas element.
	/// </summary>
	[Parameter]
	public string ChartId { get; set; } = Guid.NewGuid().ToString();

	/// <summary>
	/// The labels for the X-axis.
	/// </summary>
	[Parameter]
	public List<string> Labels { get; set; } = [];

	/// <summary>
	/// The datasets for the line chart.
	/// </summary>
	[Parameter]
	public List<LineChartDataset> Datasets { get; set; } = [];

	/// <summary>
	/// Indicates whether the chart is currently loading.
	/// </summary>
	[Parameter]
	public bool IsLoading { get; set; }

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!IsLoading && Labels.Count > 0 && Datasets.Count > 0)
		{
			try
			{
				await JSRuntime.InvokeVoidAsync("chartInterop.renderLineChart", ChartId, Labels, Datasets);
			}
			catch (Exception)
			{
				// Chart rendering failed - component will handle gracefully
			}
		}
	}

	public async ValueTask DisposeAsync()
	{
		try
		{
			await JSRuntime.InvokeVoidAsync("chartInterop.destroyChart", ChartId);
		}
		catch
		{
			// Ignore disposal errors
		}
	}

	/// <summary>
	/// Represents a dataset for the line chart.
	/// </summary>
	public class LineChartDataset
	{
		public string Label { get; set; } = string.Empty;
		public List<int> Data { get; set; } = [];
		public string BorderColor { get; set; } = "#3b82f6";
		public string BackgroundColor { get; set; } = "rgba(59, 130, 246, 0.1)";
	}
}
