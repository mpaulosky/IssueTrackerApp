@using Domain.Features.Admin.Models
@using Domain.Features.Admin.Users.Commands
@using Domain.Features.Admin.Users.Queries
@using System.Security.Claims
@using Web.Services

@inject IMediator Mediator
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toast
@inject IJSRuntime JSRuntime

@if (User is not null)
{
	<!-- Modal Overlay: tabindex enables keyboard events; focusable so Escape fires here -->
	<div class="fixed inset-0 z-50 overflow-y-auto"
	     tabindex="-1"
	     @ref="_overlayRef"
	     @onkeydown="HandleKeyDown"
	     aria-labelledby="modal-title"
	     role="dialog"
	     aria-modal="true">

		<!-- Background overlay -->
		<div class="fixed inset-0 bg-black/50 transition-opacity" @onclick="HandleClose"></div>

		<!-- Modal Container — stop click bubbling to backdrop -->
		<div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
			<div class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg"
			     @onclick:stopPropagation="true">

				<!-- Modal Header -->
				<div class="border-b border-gray-200 dark:border-gray-700 px-6 py-4">
					<div class="flex items-start justify-between">
						<h3 class="text-lg font-semibold text-gray-900 dark:text-white" id="modal-title">
							Edit Roles \u2014 @User.Name (@User.Email)
						</h3>
						<button type="button"
						        class="ml-4 flex-shrink-0 rounded-md text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
						        @onclick="HandleClose"
						        disabled="@_isSaving">
							<span class="sr-only">Close</span>
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
							</svg>
						</button>
					</div>
				</div>

				<!-- Modal Body -->
				<div class="px-6 py-4">
					@if (_isLoadingRoles)
					{
						<div class="flex justify-center py-8">
							<svg class="animate-spin h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24">
								<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
								<path class="opacity-75" fill="currentColor"
								      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
							</svg>
						</div>
					}
					else if (_step == ModalStep.Edit)
					{
						<!-- Error banner (inline — do not close on error) -->
						@if (!string.IsNullOrEmpty(_errorMessage))
						{
							<div class="mb-4 rounded-md bg-red-50 dark:bg-red-900/50 p-4">
								<div class="flex">
									<svg class="h-5 w-5 text-red-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
										<path fill-rule="evenodd"
										      d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
										      clip-rule="evenodd" />
									</svg>
									<div class="ml-3">
										<h3 class="text-sm font-medium text-red-800 dark:text-red-200">Error</h3>
										<p class="mt-1 text-sm text-red-700 dark:text-red-300">@_errorMessage</p>
									</div>
								</div>
							</div>
						}

						<!-- Role checkboxes: checked = currently assigned -->
						<div class="space-y-3">
							<p class="text-sm font-medium text-gray-700 dark:text-gray-300">
								Select roles for this user:
							</p>
							@foreach (var role in _availableRoles)
							{
								<label class="flex items-center space-x-3 p-3 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer transition-colors">
									<input type="checkbox"
									       class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 dark:border-gray-600 rounded"
									       checked="@_selectedRoles.Contains(role.RoleName)"
									       @onchange="@(e => HandleRoleToggle(role.RoleName, e))"
									       disabled="@_isSaving" />
									<span class="text-sm font-medium text-gray-900 dark:text-gray-100">@role.RoleName</span>
									@if (!string.IsNullOrEmpty(role.Description))
									{
										<span class="text-xs text-gray-500 dark:text-gray-400">\u2014 @role.Description</span>
									}
								</label>
							}
						</div>
					}
					else
					{
						<!-- Confirmation step -->
						<div class="space-y-4">
							<p class="text-sm font-medium text-gray-700 dark:text-gray-300">
								You are about to make the following role changes:
							</p>

							@if (RolesToAdd.Any())
							{
								<div class="rounded-md bg-green-50 dark:bg-green-900/30 p-3">
									<p class="text-sm font-medium text-green-800 dark:text-green-200">
										Assign: @string.Join(", ", RolesToAdd)
									</p>
								</div>
							}

							@if (RolesToRemove.Any())
							{
								<div class="rounded-md bg-red-50 dark:bg-red-900/30 p-3">
									<p class="text-sm font-medium text-red-800 dark:text-red-200">
										Remove: @string.Join(", ", RolesToRemove)
									</p>
								</div>
							}

							<!-- Inline error on confirm step — allow retry without closing -->
							@if (!string.IsNullOrEmpty(_errorMessage))
							{
								<div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4">
									<div class="flex">
										<svg class="h-5 w-5 text-red-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
											<path fill-rule="evenodd"
											      d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
											      clip-rule="evenodd" />
										</svg>
										<div class="ml-3">
											<h3 class="text-sm font-medium text-red-800 dark:text-red-200">Error</h3>
											<p class="mt-1 text-sm text-red-700 dark:text-red-300">@_errorMessage</p>
										</div>
									</div>
								</div>
							}
						</div>
					}
				</div>

				<!-- Modal Footer -->
				<div class="border-t border-gray-200 dark:border-gray-700 px-6 py-4 flex justify-end space-x-3">
					@if (_step == ModalStep.Edit)
					{
						<button type="button"
						        class="btn-secondary"
						        @onclick="HandleClose"
						        disabled="@_isSaving">
							Cancel
						</button>
						<!-- Disabled until at least one change is made -->
						<button type="button"
						        class="btn-primary"
						        @onclick="HandleProceedToConfirm"
						        disabled="@(!IsDirty || _isSaving)">
							Save Changes
						</button>
					}
					else
					{
						<button type="button"
						        class="btn-secondary"
						        @onclick="HandleBackToEdit"
						        disabled="@_isSaving">
							Back
						</button>
						<button type="button"
						        class="btn-primary inline-flex items-center"
						        @onclick="HandleConfirmSave"
						        disabled="@_isSaving">
							@if (_isSaving)
							{
								<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
									<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
									<path class="opacity-75" fill="currentColor"
									      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
								</svg>
								<span>Saving...</span>
							}
							else
							{
								<span>Confirm</span>
							}
						</button>
					}
				</div>
			</div>
		</div>
	</div>
}

@code {
	private enum ModalStep { Edit, Confirm }

	private ModalStep _step = ModalStep.Edit;
	private IReadOnlyList<RoleAssignment> _availableRoles = [];
	private HashSet<string> _selectedRoles = [];
	private HashSet<string> _initialRoles = [];
	private bool _isSaving;
	private bool _isLoadingRoles;
	private bool _shouldFocus;
	private string? _errorMessage;
	private ElementReference _overlayRef;
	private AdminUserSummary? _previousUser;

	/// <summary>The user to edit. When null the modal is hidden.</summary>
	[Parameter]
	public AdminUserSummary? User { get; set; }

	/// <summary>Invoked when the modal is closed (cancel, Escape, backdrop).</summary>
	[Parameter]
	public EventCallback OnClose { get; set; }

	/// <summary>Invoked after roles are successfully saved.</summary>
	[Parameter]
	public EventCallback OnSaved { get; set; }

	private bool IsDirty => !_selectedRoles.SetEquals(_initialRoles);
	private IEnumerable<string> RolesToAdd => _selectedRoles.Except(_initialRoles);
	private IEnumerable<string> RolesToRemove => _initialRoles.Except(_selectedRoles);

	protected override async Task OnParametersSetAsync()
	{
		if (User is not null && !ReferenceEquals(User, _previousUser))
		{
			_previousUser = User;
			_step = ModalStep.Edit;
			_errorMessage = null;
			_isSaving = false;
			_selectedRoles = [.. User.Roles];
			_initialRoles = [.. User.Roles];
			_shouldFocus = true;
			await LoadRolesAsync();
		}
		else if (User is null)
		{
			_previousUser = null;
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (_shouldFocus)
		{
			_shouldFocus = false;
			try { await _overlayRef.FocusAsync(); } catch { /* ignore if element not yet in DOM */ }
		}
	}

	private async Task LoadRolesAsync()
	{
		_isLoadingRoles = true;

		try
		{
			var result = await Mediator.Send(new ListRolesQuery());
			if (result.Success)
			{
				_availableRoles = result.Value ?? [];
			}
			else
			{
				_errorMessage = result.Error ?? "Failed to load available roles.";
			}
		}
		finally
		{
			_isLoadingRoles = false;
		}
	}

	private void HandleRoleToggle(string roleName, ChangeEventArgs e)
	{
		if (e.Value is bool isChecked)
		{
			if (isChecked) _selectedRoles.Add(roleName);
			else _selectedRoles.Remove(roleName);
		}
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Escape")
		{
			await HandleClose();
		}
	}

	private async Task HandleClose()
	{
		if (_isSaving) return;

		if (IsDirty)
		{
			var discard = await JSRuntime.InvokeAsync<bool>("confirm",
				"You have unsaved changes. Discard them?");
			if (!discard) return;
		}

		ResetState();
		await OnClose.InvokeAsync();
	}

	private void HandleProceedToConfirm()
	{
		if (!IsDirty) return;
		_errorMessage = null;
		_step = ModalStep.Confirm;
	}

	private void HandleBackToEdit()
	{
		_step = ModalStep.Edit;
		_errorMessage = null;
	}

	private async Task HandleConfirmSave()
	{
		if (User is null || _isSaving) return;

		_isSaving = true;
		_errorMessage = null;

		try
		{
			var authState = await AuthStateProvider.GetAuthenticationStateAsync();
			var adminUser = authState.User;
			var adminUserId = adminUser.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
			var adminUserName = adminUser.FindFirst(ClaimTypes.Name)?.Value
				?? adminUser.Identity?.Name
				?? "Admin";

			foreach (var roleName in RolesToAdd.ToList())
			{
				var result = await Mediator.Send(
					new AssignRoleCommand(adminUserId, adminUserName, User.UserId, roleName));

				if (result.Failure)
				{
					_errorMessage = result.Error ?? $"Failed to assign role \'{roleName}\'.";
					return;
				}
			}

			foreach (var roleName in RolesToRemove.ToList())
			{
				var result = await Mediator.Send(
					new RemoveRoleCommand(adminUserId, adminUserName, User.UserId, roleName));

				if (result.Failure)
				{
					_errorMessage = result.Error ?? $"Failed to remove role \'{roleName}\'.";
					return;
				}
			}

			Toast.ShowSuccess($"Roles updated successfully for {User.Name}.");
			ResetState();
			await OnSaved.InvokeAsync();
			await OnClose.InvokeAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = $"An unexpected error occurred: {ex.Message}";
		}
		finally
		{
			_isSaving = false;
		}
	}

	private void ResetState()
	{
		_step = ModalStep.Edit;
		_errorMessage = null;
		_availableRoles = [];
		_selectedRoles = [];
		_initialRoles = [];
		_previousUser = null;
	}
}
