@using Microsoft.AspNetCore.SignalR.Client
@using Web.Services
@implements IAsyncDisposable
@inject SignalRClientService SignalRClient

@if (ConnectionState == HubConnectionState.Connected)
{
	<div class="flex items-center gap-1.5" title="Real-time updates active">
		<span class="relative flex h-2.5 w-2.5">
			<span
			class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-600 dark:bg-green-600 opacity-75"></span>
			<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-600"></span>
		</span>
		<span class="hidden sm:inline text-green-600 dark:text-green-600">Live</span>
	</div>
}
else if (ConnectionState == HubConnectionState.Connecting || ConnectionState == HubConnectionState.Reconnecting)
{
	<div class="flex items-center gap-1.5" title="Connecting to real-time updates">
		<span class="relative flex h-2.5 w-2.5">
			<span
			class="animate-ping absolute inline-flex h-full w-full rounded-full bg-yellow-600 dark:bg-yellow-600 opacity-75"></span>
			<span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-yellow-500"></span>
		</span>
		<span class="hidden sm:inline text-yellow-600 dark:text-yellow-600">Connecting</span>
	</div>
}
else if (ConnectionState == HubConnectionState.Disconnected)
{
	<div class="flex items-center gap-1.5" title="Disconnected from real-time updates">
		<span class="flex h-2.5 w-2.5 bg-red-600 rounded-full"></span>
		<span class="hidden sm:inline text-red-600 dark:text-red-600">Offline</span>
	</div>
}

@code {
	private HubConnectionState ConnectionState { get; set; } = HubConnectionState.Disconnected;

	protected override async Task OnInitializedAsync()
	{
		SignalRClient.OnConnectionStateChanged += HandleConnectionStateChanged;
		ConnectionState = SignalRClient.ConnectionState;

		if (ConnectionState == HubConnectionState.Disconnected)
		{
			await SignalRClient.StartAsync();
		}
	}

	private void HandleConnectionStateChanged(HubConnectionState state)
	{
		ConnectionState = state;
		InvokeAsync(StateHasChanged);
	}

	public async ValueTask DisposeAsync()
	{
		SignalRClient.OnConnectionStateChanged -= HandleConnectionStateChanged;
		await Task.CompletedTask;
	}
}
