@using Domain.DTOs

<span class="@GetBadgeClasses()">
	@(Status?.StatusName ?? "Unknown")
</span>

@code {
	/// <summary>
	///   The status to display.
	/// </summary>
	[Parameter]
	public StatusDto? Status { get; set; }

	/// <summary>
	///   Optional additional CSS classes.
	/// </summary>
	[Parameter]
	public string? AdditionalClasses { get; set; }

	private string GetBadgeClasses()
	{
		var baseClasses = "badge";
		var colorClasses = GetColorClasses();
		var additionalClasses = string.IsNullOrEmpty(AdditionalClasses) ? "" : $" {AdditionalClasses}";

		return $"{baseClasses} {colorClasses}{additionalClasses}";
	}

	private string GetColorClasses()
	{
		var statusName = Status?.StatusName?.ToLowerInvariant() ?? "";

		return statusName switch
		{
			"open" => "bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200",
			"in progress" => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200",
			"under review" => "bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200",
			"resolved" => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200",
			"closed" => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200",
			"won't fix" => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200",
			_ => "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
		};
	}
}
