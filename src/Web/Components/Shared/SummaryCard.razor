<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
	<div class="flex items-center justify-between">
		<div class="flex-1">
			<p class="text-sm font-medium text-gray-600 dark:text-gray-400">@Title</p>
			<p class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">@Value</p>
			@if (!string.IsNullOrEmpty(Subtitle))
			{
				<p class="mt-1 text-xs text-gray-500 dark:text-gray-400">@Subtitle</p>
			}
		</div>
		@if (!string.IsNullOrEmpty(Icon))
		{
			<div class="flex-shrink-0">
				<div class="@IconBackgroundClass rounded-full p-3">
					@((MarkupString)Icon)
				</div>
			</div>
		}
	</div>
	@if (TrendPercentage.HasValue)
	{
		<div class="mt-4 flex items-center">
			@if (TrendPercentage.Value > 0)
			{
				<svg class="w-4 h-4 text-green-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
				</svg>
				<span class="text-sm font-medium text-green-600 dark:text-green-400">
					@($"+{TrendPercentage.Value:F1}%")
				</span>
			}
			else if (TrendPercentage.Value < 0)
			{
				<svg class="w-4 h-4 text-red-500 mr-1" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
				</svg>
				<span class="text-sm font-medium text-red-600 dark:text-red-400">
					@($"{TrendPercentage.Value:F1}%")
				</span>
			}
			else
			{
				<span class="text-sm font-medium text-gray-600 dark:text-gray-400">
					No change
				</span>
			}
			<span class="ml-2 text-xs text-gray-500 dark:text-gray-400">vs last period</span>
		</div>
	}
</div>

@code {
	/// <summary>
	/// The card title.
	/// </summary>
	[Parameter]
	public string Title { get; set; } = string.Empty;

	/// <summary>
	/// The main value to display.
	/// </summary>
	[Parameter]
	public string Value { get; set; } = string.Empty;

	/// <summary>
	/// Optional subtitle text.
	/// </summary>
	[Parameter]
	public string? Subtitle { get; set; }

	/// <summary>
	/// Optional SVG icon markup.
	/// </summary>
	[Parameter]
	public string? Icon { get; set; }

	/// <summary>
	/// Background color classes for the icon.
	/// </summary>
	[Parameter]
	public string IconBackgroundClass { get; set; } = "bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400";

	/// <summary>
	/// Optional trend percentage (positive or negative).
	/// </summary>
	[Parameter]
	public double? TrendPercentage { get; set; }
}
