@using Domain.DTOs

<div class="bg-white dark:bg-gray-800 rounded-lg shadow">
	<!-- Search Bar -->
	<div class="p-4 border-b border-gray-200 dark:border-gray-700">
		<SearchInput Value="@SearchText"
		             ValueChanged="OnSearchTextChanged"
		             OnSearch="TriggerSearch"
		             Placeholder="Search issues by title or description..."
		             DebounceMs="300"
		             Id="issue-search"
		             AriaLabel="Search issues" />
	</div>

	<!-- Collapsible Filters -->
	<div class="p-4">
		<button type="button"
		        class="flex w-full items-center justify-between text-sm font-medium text-gray-700 dark:text-gray-300"
		        @onclick="ToggleFilters"
		        aria-expanded="@_isExpanded"
		        aria-controls="filter-options">
			<span class="flex items-center">
				<svg class="mr-2 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
					<path fill-rule="evenodd" d="M2.628 1.601C5.028 1.206 7.49 1 10 1s4.973.206 7.372.601a.75.75 0 01.628.74v2.288a2.25 2.25 0 01-.659 1.59l-4.682 4.683a2.25 2.25 0 00-.659 1.59v3.037c0 .684-.31 1.33-.844 1.757l-1.937 1.55A.75.75 0 018 18.25v-5.757a2.25 2.25 0 00-.659-1.591L2.659 6.22A2.25 2.25 0 012 4.629V2.34a.75.75 0 01.628-.74z" clip-rule="evenodd" />
				</svg>
				Filters
				@if (HasActiveFilters)
				{
					<span class="ml-2 inline-flex items-center rounded-full bg-primary-100 dark:bg-primary-900 px-2 py-0.5 text-xs font-medium text-primary-800 dark:text-primary-200">
						@ActiveFilterCount active
					</span>
				}
			</span>
			<svg class="h-5 w-5 transform transition-transform duration-200 @(_isExpanded ? "rotate-180" : "")"
			     xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
				<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
			</svg>
		</button>

		@if (_isExpanded)
		{
			<div id="filter-options" class="mt-4 space-y-4">
				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
					<!-- Status Filter -->
					<div>
						<label for="status-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
							Status
						</label>
						<select id="status-filter"
						        class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white py-2 pl-3 pr-10 text-base focus:border-primary-500 focus:outline-none focus:ring-primary-500 sm:text-sm"
						        value="@StatusFilter"
						        @onchange="OnStatusChanged">
							<option value="">All Statuses</option>
							@if (Statuses is not null)
							{
								@foreach (var status in Statuses)
								{
									<option value="@status.StatusName">@status.StatusName</option>
								}
							}
						</select>
					</div>

					<!-- Category Filter -->
					<div>
						<label for="category-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
							Category
						</label>
						<select id="category-filter"
						        class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white py-2 pl-3 pr-10 text-base focus:border-primary-500 focus:outline-none focus:ring-primary-500 sm:text-sm"
						        value="@CategoryFilter"
						        @onchange="OnCategoryChanged">
							<option value="">All Categories</option>
							@if (Categories is not null)
							{
								@foreach (var category in Categories)
								{
									<option value="@category.CategoryName">@category.CategoryName</option>
								}
							}
						</select>
					</div>

					<!-- Date From -->
					<div>
						<label for="date-from" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
							From Date
						</label>
						<input type="date"
						       id="date-from"
						       class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white py-2 px-3 text-base focus:border-primary-500 focus:outline-none focus:ring-primary-500 sm:text-sm"
						       value="@DateFrom?.ToString("yyyy-MM-dd")"
						       @onchange="OnDateFromChanged" />
					</div>

					<!-- Date To -->
					<div>
						<label for="date-to" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
							To Date
						</label>
						<input type="date"
						       id="date-to"
						       class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white py-2 px-3 text-base focus:border-primary-500 focus:outline-none focus:ring-primary-500 sm:text-sm"
						       value="@DateTo?.ToString("yyyy-MM-dd")"
						       @onchange="OnDateToChanged" />
					</div>
				</div>

				<!-- Filter Actions -->
				<div class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700">
					<div class="text-sm text-gray-500 dark:text-gray-400">
						@if (TotalResults.HasValue)
						{
							<span>@TotalResults.Value results found</span>
						}
					</div>
					<div class="flex space-x-3">
						@if (HasActiveFilters)
						{
							<button type="button"
							        class="inline-flex items-center rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
							        @onclick="ClearAllFilters">
								<svg class="-ml-0.5 mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
								</svg>
								Clear All
							</button>
						}
						<button type="button"
						        class="inline-flex items-center rounded-md bg-primary-600 px-3 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
						        @onclick="ApplyFilters">
							<svg class="-ml-0.5 mr-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M2.628 1.601C5.028 1.206 7.49 1 10 1s4.973.206 7.372.601a.75.75 0 01.628.74v2.288a2.25 2.25 0 01-.659 1.59l-4.682 4.683a2.25 2.25 0 00-.659 1.59v3.037c0 .684-.31 1.33-.844 1.757l-1.937 1.55A.75.75 0 018 18.25v-5.757a2.25 2.25 0 00-.659-1.591L2.659 6.22A2.25 2.25 0 012 4.629V2.34a.75.75 0 01.628-.74z" clip-rule="evenodd" />
							</svg>
							Apply Filters
						</button>
					</div>
				</div>
			</div>
		}
	</div>
</div>

@code {
	private bool _isExpanded = false;

	/// <summary>
	///   The current search text.
	/// </summary>
	[Parameter]
	public string? SearchText { get; set; }

	/// <summary>
	///   Event callback when search text changes.
	/// </summary>
	[Parameter]
	public EventCallback<string?> SearchTextChanged { get; set; }

	/// <summary>
	///   The current status filter.
	/// </summary>
	[Parameter]
	public string? StatusFilter { get; set; }

	/// <summary>
	///   Event callback when status filter changes.
	/// </summary>
	[Parameter]
	public EventCallback<string?> StatusFilterChanged { get; set; }

	/// <summary>
	///   The current category filter.
	/// </summary>
	[Parameter]
	public string? CategoryFilter { get; set; }

	/// <summary>
	///   Event callback when category filter changes.
	/// </summary>
	[Parameter]
	public EventCallback<string?> CategoryFilterChanged { get; set; }

	/// <summary>
	///   The start date filter.
	/// </summary>
	[Parameter]
	public DateOnly? DateFrom { get; set; }

	/// <summary>
	///   Event callback when date from changes.
	/// </summary>
	[Parameter]
	public EventCallback<DateOnly?> DateFromChanged { get; set; }

	/// <summary>
	///   The end date filter.
	/// </summary>
	[Parameter]
	public DateOnly? DateTo { get; set; }

	/// <summary>
	///   Event callback when date to changes.
	/// </summary>
	[Parameter]
	public EventCallback<DateOnly?> DateToChanged { get; set; }

	/// <summary>
	///   Available statuses for the filter.
	/// </summary>
	[Parameter]
	public IEnumerable<StatusDto>? Statuses { get; set; }

	/// <summary>
	///   Available categories for the filter.
	/// </summary>
	[Parameter]
	public IEnumerable<CategoryDto>? Categories { get; set; }

	/// <summary>
	///   Total results count to display.
	/// </summary>
	[Parameter]
	public int? TotalResults { get; set; }

	/// <summary>
	///   Event callback when filters are applied.
	/// </summary>
	[Parameter]
	public EventCallback OnFiltersApplied { get; set; }

	/// <summary>
	///   Event callback when filters are cleared.
	/// </summary>
	[Parameter]
	public EventCallback OnFiltersCleared { get; set; }

	private bool HasActiveFilters =>
		!string.IsNullOrWhiteSpace(SearchText) ||
		!string.IsNullOrWhiteSpace(StatusFilter) ||
		!string.IsNullOrWhiteSpace(CategoryFilter) ||
		DateFrom.HasValue ||
		DateTo.HasValue;

	private int ActiveFilterCount
	{
		get
		{
			var count = 0;
			if (!string.IsNullOrWhiteSpace(SearchText)) count++;
			if (!string.IsNullOrWhiteSpace(StatusFilter)) count++;
			if (!string.IsNullOrWhiteSpace(CategoryFilter)) count++;
			if (DateFrom.HasValue) count++;
			if (DateTo.HasValue) count++;
			return count;
		}
	}

	private void ToggleFilters()
	{
		_isExpanded = !_isExpanded;
	}

	private async Task OnSearchTextChanged(string? value)
	{
		SearchText = value;
		await SearchTextChanged.InvokeAsync(value);
	}

	private async Task TriggerSearch(string? value)
	{
		await OnFiltersApplied.InvokeAsync();
	}

	private async Task OnStatusChanged(ChangeEventArgs e)
	{
		StatusFilter = e.Value?.ToString();
		await StatusFilterChanged.InvokeAsync(StatusFilter);
	}

	private async Task OnCategoryChanged(ChangeEventArgs e)
	{
		CategoryFilter = e.Value?.ToString();
		await CategoryFilterChanged.InvokeAsync(CategoryFilter);
	}

	private async Task OnDateFromChanged(ChangeEventArgs e)
	{
		DateFrom = string.IsNullOrEmpty(e.Value?.ToString())
			? null
			: DateOnly.Parse(e.Value.ToString()!);
		await DateFromChanged.InvokeAsync(DateFrom);
	}

	private async Task OnDateToChanged(ChangeEventArgs e)
	{
		DateTo = string.IsNullOrEmpty(e.Value?.ToString())
			? null
			: DateOnly.Parse(e.Value.ToString()!);
		await DateToChanged.InvokeAsync(DateTo);
	}

	private async Task ApplyFilters()
	{
		await OnFiltersApplied.InvokeAsync();
	}

	private async Task ClearAllFilters()
	{
		SearchText = null;
		StatusFilter = null;
		CategoryFilter = null;
		DateFrom = null;
		DateTo = null;

		await SearchTextChanged.InvokeAsync(null);
		await StatusFilterChanged.InvokeAsync(null);
		await CategoryFilterChanged.InvokeAsync(null);
		await DateFromChanged.InvokeAsync(null);
		await DateToChanged.InvokeAsync(null);
		await OnFiltersCleared.InvokeAsync();
	}
}
