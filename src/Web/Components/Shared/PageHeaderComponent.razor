<PageTitle>@HeaderText</PageTitle>

<header class="card p-2 mb-2 shadow-md">

	@switch (Level)
	{
		case "1":

			<h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">@HeaderText</h1>

			break;

		case "2":

			<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">@HeaderText</h2>

			break;

		case "3":

			<h3 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-50">@HeaderText</h3>

			break;
	}

</header>

@code {

	[Parameter] public string HeaderText { get; set; } = "My Blog";

	[Parameter] public string Level { get; set; } = "1";

}
