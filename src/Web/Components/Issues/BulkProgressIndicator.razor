@using Web.Services

@* Progress indicator for bulk operations showing real-time progress *@

@if (IsVisible)
{
	<div class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="progress-title" role="dialog" aria-modal="true">
		<div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center">
			<!-- Background overlay -->
			<div class="fixed inset-0 bg-gray-500 dark:bg-gray-900 bg-opacity-75 dark:bg-opacity-75 transition-opacity"
				aria-hidden="true"></div>

			<!-- Modal panel -->
			<div class="relative inline-block bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:max-w-lg sm:w-full">
				<div class="bg-white dark:bg-gray-800 px-6 py-6">
					<div class="text-center">
						<!-- Title -->
						<h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4" id="progress-title">
							@Title
						</h3>

						<!-- Progress bar -->
						<div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-4 mb-4 overflow-hidden">
							<div class="h-full rounded-full transition-all duration-300 ease-out @GetProgressBarClasses()"
								style="width: @(Progress?.Percentage ?? 0)%">
							</div>
						</div>

						<!-- Progress stats -->
						<div class="flex justify-between items-center text-sm text-gray-600 dark:text-gray-400 mb-4">
							<span>@(Progress?.ProcessedCount ?? 0) of @(Progress?.TotalCount ?? 0) processed</span>
							<span class="font-medium">@((Progress?.Percentage ?? 0).ToString("F0"))%</span>
						</div>

						<!-- Success/failure counts -->
						<div class="flex justify-center gap-6 mb-6">
							<div class="flex items-center gap-2">
								<div class="w-3 h-3 rounded-full bg-green-500"></div>
								<span class="text-sm text-gray-600 dark:text-gray-400">
									Success: <span class="font-medium text-green-600 dark:text-green-400">@(Progress?.SuccessCount ?? 0)</span>
								</span>
							</div>
							@if ((Progress?.FailureCount ?? 0) > 0)
							{
								<div class="flex items-center gap-2">
									<div class="w-3 h-3 rounded-full bg-red-500"></div>
									<span class="text-sm text-gray-600 dark:text-gray-400">
										Failed: <span class="font-medium text-red-600 dark:text-red-400">@(Progress?.FailureCount ?? 0)</span>
									</span>
								</div>
							}
						</div>

						<!-- Animated processing indicator -->
						@if (!IsComplete)
						{
							<div class="flex justify-center items-center gap-2 text-primary-600 dark:text-primary-400 mb-4">
								<svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
									<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
									<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
								</svg>
								<span class="text-sm">Processing...</span>
							</div>
						}
						else
						{
							<div class="flex justify-center items-center gap-2 mb-4">
								@if ((Progress?.FailureCount ?? 0) == 0)
								{
									<svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
									<span class="text-sm font-medium text-green-600 dark:text-green-400">Completed successfully!</span>
								}
								else
								{
									<svg class="h-6 w-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.834-2.694-.834-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
									</svg>
									<span class="text-sm font-medium text-yellow-600 dark:text-yellow-400">Completed with some failures</span>
								}
							</div>
						}
					</div>
				</div>

				<!-- Action buttons -->
				<div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 flex justify-end gap-3">
					@if (!IsComplete && CanCancel)
					{
						<button type="button"
							class="inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
							@onclick="OnCancelOperation">
							Cancel Operation
						</button>
					}
					@if (IsComplete)
					{
						<button type="button"
							class="inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary-600 text-sm font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
							@onclick="OnClose">
							Close
						</button>
					}
				</div>
			</div>
		</div>
	</div>
}

@code {
	/// <summary>
	/// Whether the progress indicator is visible.
	/// </summary>
	[Parameter]
	public bool IsVisible { get; set; }

	/// <summary>
	/// The title of the operation.
	/// </summary>
	[Parameter]
	public string Title { get; set; } = "Processing Bulk Operation";

	/// <summary>
	/// The current progress of the operation.
	/// </summary>
	[Parameter]
	public BulkOperationProgress? Progress { get; set; }

	/// <summary>
	/// Whether the operation is complete.
	/// </summary>
	[Parameter]
	public bool IsComplete { get; set; }

	/// <summary>
	/// Whether the operation can be cancelled.
	/// </summary>
	[Parameter]
	public bool CanCancel { get; set; } = true;

	/// <summary>
	/// Event callback when cancel is clicked.
	/// </summary>
	[Parameter]
	public EventCallback OnCancel { get; set; }

	/// <summary>
	/// Event callback when close is clicked (after completion).
	/// </summary>
	[Parameter]
	public EventCallback OnClosed { get; set; }

	private async Task OnCancelOperation()
	{
		await OnCancel.InvokeAsync();
	}

	private async Task OnClose()
	{
		await OnClosed.InvokeAsync();
	}

	private string GetProgressBarClasses()
	{
		if (Progress is null)
		{
			return "bg-primary-600";
		}

		if (Progress.FailureCount > 0)
		{
			return "bg-gradient-to-r from-primary-600 to-yellow-500";
		}

		return "bg-primary-600";
	}
}
