@using Domain.DTOs
@using Web.Components.Shared

<div class="mt-6">
	<h3 class="heading-section mb-4">
		Attachments
		@if (Attachments?.Any() == true)
		{
			<span class="ml-2 text-base text-primary-800 dark:text-primary-50">
				(@Attachments.Count)
			</span>
		}
	</h3>

	@if (_isLoading)
	{
		<!-- Loading State -->
		<div class="flex justify-center py-8">
			<svg class="animate-spin h-8 w-8 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none"
					 viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor"
							d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
				</path>
			</svg>
		</div>
	}
	else if (!string.IsNullOrEmpty(_errorMessage))
	{
		<!-- Error State -->
		<div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd"
									d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
									clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<p class="text-sm text-red-700 dark:text-red-300">@_errorMessage</p>
				</div>
			</div>
		</div>
	}
	else if (Attachments?.Any() != true)
	{
		<!-- Empty State -->
		<div
			class="text-center py-8 px-4 bg-primary-50 dark:bg-primary-900 rounded-lg border-2 border-dashed border-primary-300 dark:border-primary-700">
			<svg class="mx-auto h-12 w-12 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
							d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
			</svg>
			<p class="mt-2 text-base text-primary-800 dark:text-primary-50">No attachments yet</p>
		</div>
	}
	else
	{
		<!-- Attachment Grid -->
		<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
			@foreach (var attachment in Attachments!)
			{
				<AttachmentCard Attachment="@attachment" CanDelete="@CanDeleteAttachment(attachment)"
												OnDelete="HandleDeleteAttachment" />
			}
		</div>
	}

	<!-- Delete Confirmation Modal -->
	<DeleteConfirmationModal @bind-IsVisible="_showDeleteModal" Title="Delete Attachment"
													 Message="Are you sure you want to delete this attachment? This action cannot be undone."
													 ItemTitle="@_attachmentToDelete?.FileName" IsDeleting="@_isDeleting" OnConfirm="ConfirmDelete"
													 OnCancel="CancelDelete" />
</div>

@code {
	[Parameter]
	public IReadOnlyList<AttachmentDto>? Attachments { get; set; }

	[Parameter]
	public string? CurrentUserId { get; set; }

	[Parameter]
	public bool IsAdmin { get; set; }

	[Parameter]
	public EventCallback<string> OnAttachmentDeleted { get; set; }

	[Parameter]
	public EventCallback<string> OnError { get; set; }

	private bool _isLoading;
	private bool _showDeleteModal;
	private bool _isDeleting;
	private string? _errorMessage;
	private AttachmentDto? _attachmentToDelete;

	private bool CanDeleteAttachment(AttachmentDto attachment)
	{
		return IsAdmin || attachment.UploadedBy.Id == CurrentUserId;
	}

	private void HandleDeleteAttachment(string attachmentId)
	{
		_attachmentToDelete = Attachments?.FirstOrDefault(a => a.Id == attachmentId);
		if (_attachmentToDelete is not null)
		{
			_showDeleteModal = true;
		}
	}

	private async Task ConfirmDelete()
	{
		if (_attachmentToDelete is null)
		{
			return;
		}

		_isDeleting = true;
		_errorMessage = null;

		try
		{
			await OnAttachmentDeleted.InvokeAsync(_attachmentToDelete.Id);
			_showDeleteModal = false;
		}
		catch (Exception ex)
		{
			_errorMessage = $"Failed to delete attachment: {ex.Message}";
			await OnError.InvokeAsync(_errorMessage);
		}
		finally
		{
			_isDeleting = false;
			_attachmentToDelete = null;
		}
	}

	private void CancelDelete()
	{
		_showDeleteModal = false;
		_attachmentToDelete = null;
	}

	public void SetLoading(bool isLoading)
	{
		_isLoading = isLoading;
		StateHasChanged();
	}

	public void SetError(string error)
	{
		_errorMessage = error;
		StateHasChanged();
	}

	public void ClearError()
	{
		_errorMessage = null;
		StateHasChanged();
	}
}
