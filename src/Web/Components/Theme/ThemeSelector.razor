@* Theme Selector - Combined color + brightness picker with pill buttons *@
@* SPDX-License-Identifier: MIT *@

@implements IDisposable

<section class="card-bordered">
	<div class="card-section">
		<div class="mb-4">
			<h2 class="heading-section">Choose Your Theme</h2>
			<p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Customize your experience with different color themes</p>
		</div>

		<div class="flex flex-wrap gap-6">
			<!-- Color selector -->
			<div>
				<label class="form-label mb-2">Color:</label>
				<div class="flex gap-2">
					@foreach (var color in Colors)
					{
						<button
							type="button"
							@onclick="() => SelectColor(color.Key)"
							class="@GetColorButtonClasses(color.Key)"
							title="@color.Value.Name">
							<span class="@color.Value.DotClass w-3 h-3 rounded-full inline-block"></span>
							@color.Value.Name
						</button>
					}
				</div>
			</div>

			<!-- Brightness selector -->
			<div>
				<label class="form-label mb-2">Brightness:</label>
				<div class="flex gap-2">
					<button
						type="button"
						@onclick="() => SelectBrightness(BrightnessLight)"
						class="@GetBrightnessButtonClasses(BrightnessLight)">
						Light(Pastel)
					</button>
					<button
						type="button"
						@onclick="() => SelectBrightness(BrightnessDark)"
						class="@GetBrightnessButtonClasses(BrightnessDark)">
						Dark(Rich)
					</button>
				</div>
			</div>
		</div>

		<div class="mt-4 text-sm text-gray-600 dark:text-gray-400">
			Current: <strong class="text-primary-600 dark:text-primary-400">@GetCurrentLabel()</strong>
		</div>
	</div>
</section>

@code {
	private const string BrightnessLight = "light";
	private const string BrightnessDark = "dark";

	[CascadingParameter]
	private ThemeProvider? ThemeProvider { get; set; }

	private static readonly Dictionary<string, ColorInfo> Colors = new()
	{
		["red"] = new("Red", "bg-red-500"),
		["blue"] = new("Blue", "bg-blue-500"),
		["green"] = new("Green", "bg-green-500"),
		["yellow"] = new("Yellow", "bg-amber-500")
	};

	/// <inheritdoc />
	protected override void OnInitialized()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged += HandleThemeChanged;
		}
	}

	private void HandleThemeChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	private async Task SelectColor(string color)
	{
		if (ThemeProvider is not null)
		{
			await ThemeProvider.SetColorAsync(color);
		}
	}

	private async Task SelectBrightness(string brightness)
	{
		if (ThemeProvider is not null)
		{
			await ThemeProvider.SetBrightnessAsync(brightness);
		}
	}

	private string GetCurrentLabel()
	{
		var color = (ThemeProvider?.Color ?? "blue").ToUpperInvariant();
		var brightness = ThemeProvider?.Brightness ?? BrightnessLight;
		return $"{color} {char.ToUpper(brightness[0])}{brightness[1..]}";
	}

	private string GetColorButtonClasses(string color)
	{
		var isSelected = ThemeProvider?.Color == color;
		var baseClasses = "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium transition-colors";
		var stateClasses = isSelected
			? "bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 ring-2 ring-primary-500"
			: "bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600";
		return $"{baseClasses} {stateClasses}";
	}

	private string GetBrightnessButtonClasses(string brightness)
	{
		var isSelected = ThemeProvider?.Brightness == brightness;
		var baseClasses = "px-3 py-1.5 rounded-full text-sm font-medium transition-colors";
		var stateClasses = isSelected
			? "bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 ring-2 ring-primary-500"
			: "bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600";
		return $"{baseClasses} {stateClasses}";
	}

	/// <inheritdoc />
	public void Dispose()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged -= HandleThemeChanged;
		}
	}

	private sealed record ColorInfo(string Name, string DotClass);
}
