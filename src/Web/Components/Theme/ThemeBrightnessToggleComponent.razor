@inject IJSRuntime Js

<button @onclick="ToggleBrightnessAsync"
        class="btn brightness-btn"
        id="nav-btn-brightness-toggle"
        aria-label="Toggle brightness"
        title="@(_currentBrightness == "dark" ? "Switch to light mode" : "Switch to dark mode")">
	@if (_currentBrightness == "dark")
	{
	<!-- Sun icon - shown in dark mode (click to switch to light) -->
	<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
	</svg>
	}
	else
	{
	<!-- Moon icon - shown in light mode (click to switch to dark) -->
	<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
	</svg>
	}
</button>

@code {
	private string _currentBrightness = "light";

	/// <summary>
	/// Syncs the active state of the brightness button with the persisted theme on first render.
	/// </summary>
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			try
			{
				_currentBrightness = await Js.InvokeAsync<string>("themeManager.getBrightness") ?? "light";
				StateHasChanged();
			}
			catch (TaskCanceledException)
			{
				// Ignore task cancellation if the circuit is disconnected during initialization
			}
			catch (JSDisconnectedException)
			{
				// Ignore JS disconnection if the circuit has been disconnected
			}
		}
	}

	/// <summary>
	/// Toggles between light and dark brightness.
	/// </summary>
	private async Task ToggleBrightnessAsync()
	{
		string next = _currentBrightness == "light" ? "dark" : "light";
		try
		{
			await Js.InvokeVoidAsync("themeManager.setBrightness", next);
			_currentBrightness = next;
			StateHasChanged();
		}
		catch (TaskCanceledException)
		{
			// Ignore task cancellation during brightness toggle
		}
		catch (JSDisconnectedException)
		{
			// Ignore JS disconnection errors during user interaction
		}
	}
}
