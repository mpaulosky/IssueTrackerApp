@implements IDisposable

<div class="relative">
	<button
		type="button"
		@onclick="ToggleDropdown"
		class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500"
		aria-label="Toggle theme"
		title="@GetCurrentModeTitle()">
		@if (ThemeProvider?.IsDarkMode == true)
		{
			<!-- Moon icon for dark mode -->
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
			</svg>
		}
		else
		{
			<!-- Sun icon for light mode -->
			<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
			</svg>
		}
	</button>

	@if (_isOpen)
	{
		<div class="absolute right-0 mt-2 w-36 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50">
			<div class="py-1" role="menu" aria-orientation="vertical">
				<button
					type="button"
					@onclick="() => SetThemeMode(ThemeModeLight)"
					class="@GetMenuItemClasses(ThemeModeLight)"
					role="menuitem">
					<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
					</svg>
					Light
				</button>
				<button
					type="button"
					@onclick="() => SetThemeMode(ThemeModeDark)"
					class="@GetMenuItemClasses(ThemeModeDark)"
					role="menuitem">
					<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
					</svg>
					Dark
				</button>
				<button
					type="button"
					@onclick="() => SetThemeMode(ThemeModeSystem)"
					class="@GetMenuItemClasses(ThemeModeSystem)"
					role="menuitem">
					<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
					</svg>
					System
				</button>
			</div>
		</div>
	}
</div>

@code {
	private const string ThemeModeLight = "light";
	private const string ThemeModeDark = "dark";
	private const string ThemeModeSystem = "system";

	[CascadingParameter]
	private ThemeProvider? ThemeProvider { get; set; }

	private bool _isOpen;

	/// <inheritdoc />
	protected override void OnInitialized()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged += HandleThemeChanged;
		}
	}

	private void HandleThemeChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	private void ToggleDropdown()
	{
		_isOpen = !_isOpen;
	}

	private async Task SetThemeMode(string mode)
	{
		if (ThemeProvider is not null)
		{
			await ThemeProvider.SetThemeModeAsync(mode);
		}
		_isOpen = false;
	}

	private string GetCurrentModeTitle()
	{
		return ThemeProvider?.ThemeMode switch
		{
			ThemeModeLight => "Light mode",
			ThemeModeDark => "Dark mode",
			_ => "System theme"
		};
	}

	private string GetMenuItemClasses(string mode)
	{
		var isSelected = ThemeProvider?.ThemeMode == mode;
		var baseClasses = "flex items-center w-full px-4 py-2 text-sm";
		var stateClasses = isSelected
			? "text-primary-600 bg-primary-50 dark:text-primary-400 dark:bg-primary-900/20"
			: "text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700";
		return $"{baseClasses} {stateClasses}";
	}

	/// <inheritdoc />
	public void Dispose()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged -= HandleThemeChanged;
		}
	}
}
