@* Color Scheme Selector - Allows users to choose accent color *@
@* SPDX-License-Identifier: MIT *@

@implements IDisposable

<div class="relative">
	<button
		type="button"
		@onclick="ToggleDropdown"
		class="p-2 rounded-lg text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500"
		aria-label="Change color scheme"
		title="Color scheme">
		<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
		</svg>
	</button>

	@if (_isOpen)
	{
		<div class="absolute right-0 mt-2 w-40 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50">
			<div class="py-2 px-2" role="menu" aria-orientation="vertical">
				<p class="text-xs font-medium text-gray-500 dark:text-gray-400 px-2 mb-2">Color Theme</p>
				<div class="grid grid-cols-2 gap-2">
					@foreach (var scheme in ColorSchemes)
					{
						<button
							type="button"
							@onclick="() => SelectColorScheme(scheme.Key)"
							class="@GetSchemeButtonClasses(scheme.Key)"
							role="menuitem"
							title="@scheme.Value.Name">
							<span class="@scheme.Value.SampleClass w-4 h-4 rounded-full"></span>
							<span class="text-xs">@scheme.Value.Name</span>
						</button>
					}
				</div>
			</div>
		</div>
	}
</div>

@code {
	[CascadingParameter]
	private ThemeProvider? ThemeProvider { get; set; }

	private bool _isOpen;

	private static readonly Dictionary<string, ColorSchemeInfo> ColorSchemes = new()
	{
		["blue"] = new("Blue", "bg-blue-500"),
		["red"] = new("Red", "bg-red-500"),
		["green"] = new("Green", "bg-green-500"),
		["yellow"] = new("Yellow", "bg-amber-500")
	};

	/// <inheritdoc />
	protected override void OnInitialized()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged += HandleThemeChanged;
		}
	}

	private void HandleThemeChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	private void ToggleDropdown()
	{
		_isOpen = !_isOpen;
	}

	private async Task SelectColorScheme(string scheme)
	{
		if (ThemeProvider is not null)
		{
			await ThemeProvider.SetColorSchemeAsync(scheme);
		}
		_isOpen = false;
	}

	private string GetSchemeButtonClasses(string scheme)
	{
		var isSelected = ThemeProvider?.ColorScheme == scheme;
		var baseClasses = "flex flex-col items-center gap-1 p-2 rounded-lg transition-colors";
		var stateClasses = isSelected
			? "bg-gray-100 dark:bg-gray-700 ring-2 ring-primary-500"
			: "hover:bg-gray-50 dark:hover:bg-gray-700";
		return $"{baseClasses} {stateClasses}";
	}

	/// <inheritdoc />
	public void Dispose()
	{
		if (ThemeProvider is not null)
		{
			ThemeProvider.OnThemeChanged -= HandleThemeChanged;
		}
	}

	private sealed record ColorSchemeInfo(string Name, string SampleClass);
}
