@* Theme Provider - Manages dark mode and color scheme state *@

@implements IAsyncDisposable

<CascadingValue Value="this">
	@ChildContent
</CascadingValue>

@code {
	/// <summary>
	/// Child content to render within the theme provider context
	/// </summary>
	[Parameter]
	public RenderFragment? ChildContent { get; set; }
}
