@page "/admin/statuses"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Web.Auth
@using Web.Services
@using Domain.DTOs
@using Web.Components.Shared

@inject IStatusService StatusService
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize(Policy = AuthorizationPolicies.AdminPolicy)]
@attribute [StreamRendering]

<PageTitle>Statuses - Admin - IssueTracker</PageTitle>

<AdminPageLayout Title="Statuses" Description="Manage issue statuses used throughout the application.">
	<!-- Action Bar -->
	<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
		<div class="flex items-center space-x-4">
			<label class="inline-flex items-center">
				<input type="checkbox"
				       class="rounded border-gray-300 dark:border-gray-600 text-primary-600 shadow-sm focus:ring-primary-500"
				       @bind="_includeArchived"
				       @bind:after="LoadStatusesAsync" />
				<span class="ml-2 text-sm text-gray-600 dark:text-gray-400">Show archived</span>
			</label>
		</div>
		<button type="button"
		        class="inline-flex items-center justify-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900"
		        @onclick="OpenCreateModal">
			<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
				<path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
			</svg>
			Create Status
		</button>
	</div>

	<!-- Error Message -->
	@if (!string.IsNullOrEmpty(_errorMessage))
	{
		<div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4 mb-6">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<p class="text-sm font-medium text-red-800 dark:text-red-200">@_errorMessage</p>
				</div>
				<div class="ml-auto pl-3">
					<button type="button" class="text-red-500 hover:text-red-600" @onclick="() => _errorMessage = null">
						<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
							<path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
						</svg>
					</button>
				</div>
			</div>
		</div>
	}

	<!-- Success Message -->
	@if (!string.IsNullOrEmpty(_successMessage))
	{
		<div class="rounded-md bg-green-50 dark:bg-green-900/50 p-4 mb-6">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<p class="text-sm font-medium text-green-800 dark:text-green-200">@_successMessage</p>
				</div>
				<div class="ml-auto pl-3">
					<button type="button" class="text-green-500 hover:text-green-600" @onclick="() => _successMessage = null">
						<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
							<path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
						</svg>
					</button>
				</div>
			</div>
		</div>
	}

	<!-- Loading State -->
	@if (_isLoading)
	{
		<div class="flex justify-center py-12">
			<svg class="animate-spin h-8 w-8 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
			</svg>
		</div>
	}
	else if (_statuses is null || !_statuses.Any())
	{
		<!-- Empty State -->
		<div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg shadow">
			<svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
			</svg>
			<h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No statuses</h3>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by creating a new status.</p>
			<div class="mt-6">
				<button type="button"
				        class="inline-flex items-center rounded-md bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-700"
				        @onclick="OpenCreateModal">
					<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
						<path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
					</svg>
					Create Status
				</button>
			</div>
		</div>
	}
	else
	{
		<!-- Statuses Table -->
		<div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
			<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
				<thead class="bg-gray-50 dark:bg-gray-700">
					<tr>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
							Name
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
							Description
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
							Status
						</th>
						<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
							Created
						</th>
						<th scope="col" class="relative px-6 py-3">
							<span class="sr-only">Actions</span>
						</th>
					</tr>
				</thead>
				<tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
					@foreach (var status in _statuses)
					{
						<tr class="@(status.Archived ? "bg-gray-50 dark:bg-gray-900/50" : "")">
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="text-sm font-medium text-gray-900 dark:text-white">
									@status.StatusName
								</div>
							</td>
							<td class="px-6 py-4">
								<div class="text-sm text-gray-500 dark:text-gray-400 max-w-xs truncate" title="@status.StatusDescription">
									@status.StatusDescription
								</div>
							</td>
							<td class="px-6 py-4 whitespace-nowrap">
								@if (status.Archived)
								{
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
										Archived
									</span>
								}
								else
								{
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-300">
										Active
									</span>
								}
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
								@status.DateCreated.ToString("MMM d, yyyy")
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
								<button type="button"
								        class="text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300"
								        @onclick="() => OpenEditModal(status)">
									Edit
								</button>
								@if (status.Archived)
								{
									<button type="button"
									        class="text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300"
									        @onclick="() => ToggleArchive(status)">
										Restore
									</button>
								}
								else
								{
									<button type="button"
									        class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300"
									        @onclick="() => ToggleArchive(status)">
										Archive
									</button>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</AdminPageLayout>

<!-- Create/Edit Modal -->
@if (_showModal)
{
	<div class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
		<div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
			<div class="fixed inset-0 bg-gray-500 dark:bg-gray-900 bg-opacity-75 dark:bg-opacity-75 transition-opacity"
			     @onclick="CloseModal"></div>

			<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>

			<div class="relative inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
				<EditForm Model="@_model" OnValidSubmit="HandleSubmit">
					<DataAnnotationsValidator />

					<div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
						<h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">
							@(_isEditing ? "Edit Status" : "Create Status")
						</h3>

						<div class="space-y-4">
							<div>
								<label for="status-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
									Name <span class="text-red-500">*</span>
								</label>
								<InputText id="status-name"
								           @bind-Value="_model.Name"
								           class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm"
								           placeholder="Enter status name" />
								<ValidationMessage For="@(() => _model.Name)" class="mt-1 text-sm text-red-600 dark:text-red-400" />
							</div>

							<div>
								<label for="status-description" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
									Description <span class="text-red-500">*</span>
								</label>
								<InputTextArea id="status-description"
								               @bind-Value="_model.Description"
								               rows="3"
								               class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm"
								               placeholder="Enter status description" />
								<ValidationMessage For="@(() => _model.Description)" class="mt-1 text-sm text-red-600 dark:text-red-400" />
							</div>
						</div>
					</div>

					<div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse gap-3">
						<button type="submit"
						        disabled="@_isSubmitting"
						        class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary-600 text-base font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed">
							@if (_isSubmitting)
							{
								<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
									<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
									<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
								</svg>
								<span>Saving...</span>
							}
							else
							{
								<span>@(_isEditing ? "Update" : "Create")</span>
							}
						</button>
						<button type="button"
						        class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 sm:mt-0 sm:w-auto sm:text-sm"
						        @onclick="CloseModal">
							Cancel
						</button>
					</div>
				</EditForm>
			</div>
		</div>
	</div>
}

@code {
	private IEnumerable<StatusDto>? _statuses;
	private bool _isLoading = true;
	private bool _includeArchived;
	private string? _errorMessage;
	private string? _successMessage;

	private bool _showModal;
	private bool _isEditing;
	private bool _isSubmitting;
	private string? _editingId;
	private StatusModel _model = new();

	protected override async Task OnInitializedAsync()
	{
		await LoadStatusesAsync();
	}

	private async Task LoadStatusesAsync()
	{
		_isLoading = true;
		_errorMessage = null;

		try
		{
			var result = await StatusService.GetStatusesAsync(_includeArchived);
			if (result.Success)
			{
				_statuses = result.Value;
			}
			else
			{
				_errorMessage = result.Error ?? "Failed to load statuses";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private void OpenCreateModal()
	{
		_model = new StatusModel();
		_isEditing = false;
		_editingId = null;
		_showModal = true;
	}

	private void OpenEditModal(StatusDto status)
	{
		_model = new StatusModel
		{
			Name = status.StatusName,
			Description = status.StatusDescription
		};
		_isEditing = true;
		_editingId = status.Id.ToString();
		_showModal = true;
	}

	private void CloseModal()
	{
		_showModal = false;
		_model = new StatusModel();
		_isEditing = false;
		_editingId = null;
	}

	private async Task HandleSubmit()
	{
		if (_isSubmitting)
		{
			return;
		}

		_isSubmitting = true;
		_errorMessage = null;
		_successMessage = null;

		try
		{
			Domain.Abstractions.Result<StatusDto> result;

			if (_isEditing && !string.IsNullOrEmpty(_editingId))
			{
				result = await StatusService.UpdateStatusAsync(
					_editingId,
					_model.Name!,
					_model.Description!);

				if (result.Success)
				{
					_successMessage = $"Status '{_model.Name}' updated successfully.";
				}
			}
			else
			{
				result = await StatusService.CreateStatusAsync(
					_model.Name!,
					_model.Description!);

				if (result.Success)
				{
					_successMessage = $"Status '{_model.Name}' created successfully.";
				}
			}

			if (result.Success)
			{
				CloseModal();
				await LoadStatusesAsync();
			}
			else
			{
				_errorMessage = result.Error ?? "Operation failed";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isSubmitting = false;
		}
	}

	private async Task ToggleArchive(StatusDto status)
	{
		_errorMessage = null;
		_successMessage = null;

		try
		{
			var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			var user = authState.User;

			var currentUser = new UserDto(
				user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
				user.Identity?.Name ?? "Unknown",
				user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "");

			var result = await StatusService.ArchiveStatusAsync(
				status.Id.ToString(),
				!status.Archived,
				currentUser);

			if (result.Success)
			{
				var action = status.Archived ? "restored" : "archived";
				_successMessage = $"Status '{status.StatusName}' {action} successfully.";
				await LoadStatusesAsync();
			}
			else
			{
				_errorMessage = result.Error ?? "Operation failed";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private sealed class StatusModel
	{
		[System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
		[System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 100 characters")]
		public string? Name { get; set; }

		[System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Description is required")]
		[System.ComponentModel.DataAnnotations.StringLength(500, MinimumLength = 5, ErrorMessage = "Description must be between 5 and 500 characters")]
		public string? Description { get; set; }
	}
}
