@* ⚠️  COMPONENT WRAPPER — NOT A LAYOUT
   Use:    <AdminPageLayout Title="..." Description="...">...</AdminPageLayout>
   Do NOT: @layout AdminPageLayout  (this component does NOT inherit LayoutComponentBase)
*@
<div class="min-h-screen bg-primary-500 dark:bg-primary-900 transition-colors duration-200">
	<!-- Admin Navigation Bar -->
	<nav class="bg-primary-400 dark:bg-primary-400 border-b-2 border-primary-800 w-full py-2">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex justify-between h-12 items-center">
				<div class="flex items-center">
					<a href="/admin" class="text-xl font-bold text-primary-900 dark:text-white mr-8">
						Admin Portal
					</a>
					<div class="hidden sm:flex sm:space-x-1">
						<NavLink href="/admin" Match="NavLinkMatch.All"
						         class="@GetNavLinkClass("/admin")">
							Dashboard
						</NavLink>
						<NavLink href="/admin/analytics"
						         class="@GetNavLinkClass("/admin/analytics")">
							Analytics
						</NavLink>
						<NavLink href="/admin/categories"
						         class="@GetNavLinkClass("/admin/categories")">
							Categories
						</NavLink>
						<NavLink href="/admin/statuses"
						         class="@GetNavLinkClass("/admin/statuses")">
							Statuses
						</NavLink>
						<NavLink href="/admin/users"
						         class="@GetNavLinkClass("/admin/users")">
							Users
						</NavLink>
					</div>
				</div>
				<div class="flex items-center">
					<a href="/"
					   class="inline-flex items-center px-3 py-2 text-sm font-medium rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">
						<svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
						</svg>
						Back to App
					</a>
				</div>
			</div>
		</div>
	</nav>

	<!-- Page Content -->
	<main class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8 text-primary-900 dark:text-primary-200">
		@if (!string.IsNullOrEmpty(Title))
		{
			<div class="mb-6">
				<h1 class="heading-page">@Title</h1>
				@if (!string.IsNullOrEmpty(Description))
				{
					<p class="mt-1 text-sm text-primary-700 dark:text-primary-300">@Description</p>
				}
			</div>
		}

		@ChildContent
	</main>
</div>

@code {
	/// <summary>
	///   The page title.
	/// </summary>
	[Parameter]
	public string? Title { get; set; }

	/// <summary>
	///   The page description.
	/// </summary>
	[Parameter]
	public string? Description { get; set; }

	/// <summary>
	///   The child content to render.
	/// </summary>
	[Parameter]
	public RenderFragment? ChildContent { get; set; }

	[Inject]
	private NavigationManager NavigationManager { get; set; } = default!;

	private string GetNavLinkClass(string href)
	{
		var currentUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
		var currentPath = "/" + currentUri.Split('?')[0];

		var isActive = href == "/admin"
			? currentPath == "/admin"
			: currentPath.StartsWith(href, StringComparison.OrdinalIgnoreCase);

		return isActive
			? "border-primary-900 dark:border-white text-primary-900 dark:text-white inline-flex items-center px-3 py-2 border-b-2 text-sm font-medium rounded"
			: "border-transparent inline-flex items-center px-3 py-2 border-b-2 text-sm font-medium rounded hover:bg-primary-100 hover:text-primary-700 transition-colors";
	}
}
