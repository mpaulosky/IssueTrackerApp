@page "/admin/categories"
@using Web.Auth
@using Web.Services
@using Domain.DTOs

@inject ICategoryService CategoryService
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize(Policy = AuthorizationPolicies.AdminPolicy)]
@attribute [StreamRendering]

<AdminPageLayout Title="Categories" Description="Manage issue categories used throughout the application.">
	<!-- Action Bar -->
	<div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
		<div class="flex items-center space-x-4">
			<label class="inline-flex items-center">
				<input type="checkbox"
							 class="rounded border-primary-300 dark:border-primary-600 text-primary-600 shadow-sm focus:ring-primary-500"
							 @bind="_includeArchived" @bind:after="LoadCategoriesAsync" />
				<span class="ml-2 text-sm text-primary-600 dark:text-primary-400">Show archived</span>
			</label>
		</div>
		<button type="button" class="btn btn-primary justify-center dark:focus:ring-offset-primary-900"
						@onclick="OpenCreateModal">
			<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
				<path
				d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
			</svg>
			Create Category
		</button>
	</div>

	<!-- Error Message -->
	@if (!string.IsNullOrEmpty(_errorMessage))
	{
		<div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4 mb-6">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd"
									d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
									clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<p class="text-sm font-medium text-red-800 dark:text-red-200">@_errorMessage</p>
				</div>
				<div class="ml-auto pl-3">
					<button type="button" class="text-red-500 hover:text-red-600" @onclick="() => _errorMessage = null">
						<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
							<path
							d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
						</svg>
					</button>
				</div>
			</div>
		</div>
	}

	<!-- Success Message -->
	@if (!string.IsNullOrEmpty(_successMessage))
	{
		<div class="rounded-md bg-green-50 dark:bg-green-900/50 p-4 mb-6">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd"
									d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
									clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<p class="text-sm font-medium text-green-800 dark:text-green-200">@_successMessage</p>
				</div>
				<div class="ml-auto pl-3">
					<button type="button" class="text-green-500 hover:text-green-600" @onclick="() => _successMessage = null">
						<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
							<path
							d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
						</svg>
					</button>
				</div>
			</div>
		</div>
	}

	<!-- Loading State -->
	@if (_isLoading)
	{
		<div class="flex justify-center py-12">
			<svg class="animate-spin h-8 w-8 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none"
					 viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor"
							d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
				</path>
			</svg>
		</div>
	}
	else if (_categories is null || !_categories.Any())
	{
		<!-- Empty State -->
		<div class="card text-center py-12">
			<svg class="mx-auto h-12 w-12 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
							d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
			</svg>
			<h3 class="mt-2 text-sm font-medium text-primary-900 dark:text-white">No categories</h3>
			<p class="mt-1 text-sm text-primary-500 dark:text-primary-400">Get started by creating a new category.</p>
			<div class="mt-6">
				<button type="button" class="btn btn-primary" @onclick="OpenCreateModal">
					<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
						<path
						d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
					</svg>
					Create Category
				</button>
			</div>
		</div>
	}
	else
	{
		<!-- Categories Table -->
		<div class="bg-primary-200 dark:bg-primary-800 shadow overflow-hidden sm:rounded-lg">
			<table class="min-w-full divide-y divide-primary-200 dark:divide-primary-700">
				<thead class="bg-primary-200 dark:bg-primary-700">
					<tr>
						<th scope="col"
								class="px-6 py-3 text-left text-xs font-medium text-primary-500 dark:text-primary-300 uppercase tracking-wider">
							Name
						</th>
						<th scope="col"
								class="px-6 py-3 text-left text-xs font-medium text-primary-500 dark:text-primary-300 uppercase tracking-wider">
							Description
						</th>
						<th scope="col"
								class="px-6 py-3 text-left text-xs font-medium text-primary-500 dark:text-primary-300 uppercase tracking-wider">
							Status
						</th>
						<th scope="col"
								class="px-6 py-3 text-left text-xs font-medium text-primary-500 dark:text-primary-300 uppercase tracking-wider">
							Created
						</th>
						<th scope="col" class="relative px-6 py-3">
							<span class="sr-only">Actions</span>
						</th>
					</tr>
				</thead>
				<tbody class="bg-white dark:bg-primary-800 divide-y divide-primary-200 dark:divide-primary-700">
					@foreach (var category in _categories)
					{
						<tr class="@(category.Archived ? "bg-primary-50 dark:bg-primary-900/50" : "")">
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="text-sm font-medium text-primary-900 dark:text-white">
									@category.CategoryName
								</div>
							</td>
							<td class="px-6 py-4">
								<div class="text-sm text-primary-500 dark:text-primary-400 max-w-xs truncate"
										 title="@category.CategoryDescription">
									@category.CategoryDescription
								</div>
							</td>
							<td class="px-6 py-4 whitespace-nowrap">
								@if (category.Archived)
								{
									<span class="badge bg-primary-100 dark:bg-primary-700 text-primary-800 dark:text-primary-300">
										Archived
									</span>
								}
								else
								{
									<span class="badge bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-300">
										Active
									</span>
								}
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-primary-500 dark:text-primary-400">
								@category.DateCreated.ToString("MMM d, yyyy")
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
								<button type="button"
												class="text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300"
												@onclick="() => OpenEditModal(category)">
									Edit
								</button>
								@if (category.Archived)
								{
									<button type="button"
													class="text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300"
													@onclick="() => ToggleArchive(category)">
										Restore
									</button>
								}
								else
								{
									<button type="button" class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300"
													@onclick="() => ToggleArchive(category)">
										Archive
									</button>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</AdminPageLayout>

<!-- Create/Edit Modal -->
@if (_showModal)
{
	<div class="modal-overlay" aria-labelledby="modal-title" role="dialog" aria-modal="true">
		<div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
			<div class="modal-backdrop" @onclick="CloseModal"></div>

			<span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>

			<div class="modal-panel">
				<EditForm Model="@_model" OnValidSubmit="HandleSubmit">
					<DataAnnotationsValidator />

					<div class="modal-body">
						<h3 class="text-lg leading-6 font-medium text-primary-900 dark:text-white mb-4">
							@(_isEditing ? "Edit Category" : "Create Category")
						</h3>

						<div class="space-y-4">
							<div>
								<label for="category-name" class="form-label">
									Name <span class="text-red-500">*</span>
								</label>
								<InputText id="category-name" @bind-Value="_model.Name" class="form-input mt-1"
													 placeholder="Enter category name" />
								<ValidationMessage For="@(() => _model.Name)" class="mt-1 text-sm text-red-600 dark:text-red-400" />
							</div>

							<div>
								<label for="category-description" class="form-label">
									Description <span class="text-red-500">*</span>
								</label>
								<InputTextArea id="category-description" @bind-Value="_model.Description" rows="3" class="form-input mt-1"
															 placeholder="Enter category description" />
								<ValidationMessage For="@(() => _model.Description)"
																	 class="mt-1 text-sm text-red-600 dark:text-red-400" />
							</div>
						</div>
					</div>

					<div class="card-footer gap-3">
						<button type="submit" disabled="@_isSubmitting" class="btn btn-primary w-full justify-center sm:w-auto">
							@if (_isSubmitting)
							{
								<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none"
										 viewBox="0 0 24 24">
									<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
									<path class="opacity-75" fill="currentColor"
												d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
									</path>
								</svg>
								<span>Saving...</span>
							}
							else
							{
								<span>@(_isEditing ? "Update" : "Create")</span>
							}
						</button>
						<button type="button" class="btn btn-secondary mt-3 w-full justify-center sm:mt-0 sm:w-auto"
										@onclick="CloseModal">
							Cancel
						</button>
					</div>
				</EditForm>
			</div>
		</div>
	</div>
}

@code {

	private const string PageTitle = "Categories - Admin - IssueTracker";

	private IEnumerable<CategoryDto>? _categories;
	private bool _isLoading = true;
	private bool _includeArchived;
	private string? _errorMessage;
	private string? _successMessage;

	private bool _showModal;
	private bool _isEditing;
	private bool _isSubmitting;
	private string? _editingId;
	private CategoryModel _model = new();

	protected override async Task OnInitializedAsync()
	{
		await LoadCategoriesAsync();
	}

	private async Task LoadCategoriesAsync()
	{
		_isLoading = true;
		_errorMessage = null;

		try
		{
			var result = await CategoryService.GetCategoriesAsync(_includeArchived);
			if (result.Success)
			{
				_categories = result.Value;
			}
			else
			{
				_errorMessage = result.Error ?? "Failed to load categories";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private void OpenCreateModal()
	{
		_model = new CategoryModel();
		_isEditing = false;
		_editingId = null;
		_showModal = true;
	}

	private void OpenEditModal(CategoryDto category)
	{
		_model = new CategoryModel
		{
			Name = category.CategoryName,
			Description = category.CategoryDescription
		};
		_isEditing = true;
		_editingId = category.Id.ToString();
		_showModal = true;
	}

	private void CloseModal()
	{
		_showModal = false;
		_model = new CategoryModel();
		_isEditing = false;
		_editingId = null;
	}

	private async Task HandleSubmit()
	{
		if (_isSubmitting)
		{
			return;
		}

		_isSubmitting = true;
		_errorMessage = null;
		_successMessage = null;

		try
		{
			Domain.Abstractions.Result<CategoryDto> result;

			if (_isEditing && !string.IsNullOrEmpty(_editingId))
			{
				result = await CategoryService.UpdateCategoryAsync(
					_editingId,
					_model.Name!,
					_model.Description!);

				if (result.Success)
				{
					_successMessage = $"Category '{_model.Name}' updated successfully.";
				}
			}
			else
			{
				result = await CategoryService.CreateCategoryAsync(
					_model.Name!,
					_model.Description!);

				if (result.Success)
				{
					_successMessage = $"Category '{_model.Name}' created successfully.";
				}
			}

			if (result.Success)
			{
				CloseModal();
				await LoadCategoriesAsync();
			}
			else
			{
				_errorMessage = result.Error ?? "Operation failed";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isSubmitting = false;
		}
	}

	private async Task ToggleArchive(CategoryDto category)
	{
		_errorMessage = null;
		_successMessage = null;

		try
		{
			var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			var user = authState.User;

			var currentUser = new UserDto(
				user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
				user.Identity?.Name ?? "Unknown",
				user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "");

			var result = await CategoryService.ArchiveCategoryAsync(
				category.Id.ToString(),
				!category.Archived,
				currentUser);

			if (result.Success)
			{
				var action = category.Archived ? "restored" : "archived";
				_successMessage = $"Category '{category.CategoryName}' {action} successfully.";
				await LoadCategoriesAsync();
			}
			else
			{
				_errorMessage = result.Error ?? "Operation failed";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private sealed class CategoryModel
	{
		[System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
		[System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 100 characters")]
		public string? Name { get; set; }

		[System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Description is required")]
		[System.ComponentModel.DataAnnotations.StringLength(500, MinimumLength = 5, ErrorMessage = "Description must be between 5 and 500 characters")]
		public string? Description { get; set; }
	}
}
