@page "/issues"
@using Microsoft.AspNetCore.WebUtilities
@using Web.Auth
@using Web.Services
@using Domain.DTOs
@implements IAsyncDisposable

@inject IIssueService IssueService
@inject ILookupService LookupService
@inject NavigationManager NavigationManager
@inject SignalRClientService SignalRClient
@inject BulkSelectionState BulkSelectionState
@inject IBulkOperationService BulkOperationService
@inject ToastService ToastService
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize(Policy = AuthorizationPolicies.UserPolicy)]
@attribute [StreamRendering]

<PageHeaderComponent Level="1" HeaderText="@PageTitle" />

<div class="space-y-6">
	<!-- Bulk Action Toolbar -->
	<BulkActionToolbar Statuses="@_statuses" Categories="@_categories" IsAdmin="@_isAdmin"
										 OnChangeStatus="HandleBulkStatusChange" OnChangeCategory="HandleBulkCategoryChange" OnDelete="HandleBulkDelete"
										 OnExport="HandleBulkExport" />

	<!-- Header -->
	<div class="sm:flex sm:items-center sm:justify-between">
		<div>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
				Manage and track all issues in the system.
			</p>
		</div>
		<div class="mt-4 sm:mt-0">
			<a href="/issues/create" class="btn-primary justify-center dark:focus:ring-offset-gray-900">
				<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
					<path
					d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
				</svg>
				Create Issue
			</a>
		</div>
	</div>

	<!-- Search and Filter Panel -->
	<FilterPanel SearchText="@_searchText" SearchTextChanged="OnSearchTextChanged" StatusFilter="@_statusFilter"
							 StatusFilterChanged="OnStatusFilterChanged" CategoryFilter="@_categoryFilter"
							 CategoryFilterChanged="OnCategoryFilterChanged" DateFrom="@_dateFrom" DateFromChanged="OnDateFromChanged"
							 DateTo="@_dateTo" DateToChanged="OnDateToChanged" Statuses="@_statuses" Categories="@_categories"
							 TotalResults="@((int?)_totalItems)" OnFiltersApplied="OnFiltersApplied" OnFiltersCleared="OnFiltersCleared" />

	<!-- Quick sort: Top Voted -->
	<div class="flex items-center gap-2">
		<button type="button" @onclick="ToggleTopVoted"
						class="@(_sortByVotes ? "btn-primary text-xs px-3 py-1.5" : "btn-secondary text-xs px-3 py-1.5")">
			▲ Top Voted
		</button>
	</div>

	<!-- Issues List -->
	@if (_isLoading)
	{
		<div class="flex justify-center py-12">
			<svg class="animate-spin h-8 w-8 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none"
					 viewBox="0 0 24 24">
				<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
				<path class="opacity-75" fill="currentColor"
							d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
				</path>
			</svg>
		</div>
	}
	else if (!string.IsNullOrEmpty(_errorMessage))
	{
		<div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4" role="alert">
			<div class="flex">
				<div class="flex-shrink-0">
					<svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
						<path fill-rule="evenodd"
									d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
									clip-rule="evenodd" />
					</svg>
				</div>
				<div class="ml-3">
					<h3 class="text-sm font-medium text-red-800 dark:text-red-200">Error loading issues</h3>
					<p class="mt-1 text-sm text-red-700 dark:text-red-300">@_errorMessage</p>
				</div>
			</div>
		</div>
	}
	else if (_issues is null || !_issues.Any())
	{
		<div class="text-center py-12">
			<svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
							d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
			</svg>
			<h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No issues found</h3>
			<p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
				@if (HasActiveFilters)
				{
					<span>Try adjusting your filters or </span>
				}
				<span>create a new issue to get started.</span>
			</p>
			<div class="mt-6">
				<a href="/issues/create" class="btn-primary">
					<svg class="-ml-0.5 mr-1.5 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
						<path
						d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
					</svg>
					Create Issue
				</a>
			</div>
		</div>
	}
	else
	{
		<div class="card overflow-hidden sm:rounded-lg">
			<!-- Table header with Select All checkbox -->
			<div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
				<div class="flex items-center gap-4">
					<IssueMultiSelect ShowSelectAll="true" AllIssueIds="@_issues?.Select(i => i.Id.ToString())" />
					<span class="text-xs text-gray-500 dark:text-gray-400">
						Select issues for bulk actions
					</span>
				</div>
			</div>
			<ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
				@foreach (var issue in DisplayedIssues)
				{
					<li>
						<div class="flex items-center hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
							<!-- Checkbox column -->
							<div class="pl-4 py-4">
								<IssueMultiSelect IssueId="@issue.Id.ToString()" />
							</div>
							<!-- Issue content -->
							<a href="/issues/@issue.Id" class="flex-1 block">
								<div class="px-4 py-4 sm:px-6">
									<div class="flex items-center justify-between">
										<div class="flex items-center space-x-3 min-w-0">
											<p class="text-sm font-medium text-primary-600 dark:text-primary-400 truncate">
												@issue.Title
											</p>
											<StatusBadge Status="@issue.Status" />
											<CategoryBadge Category="@issue.Category" />
											@if (issue.Votes > 0)
											{
												<span class="inline-flex items-center text-xs font-semibold text-indigo-600 dark:text-indigo-400" title="@issue.Votes vote(s)">
													▲ @issue.Votes
												</span>
											}
										</div>
										<div class="ml-2 flex-shrink-0">
											<svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"
													 fill="currentColor">
												<path fill-rule="evenodd"
															d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
															clip-rule="evenodd" />
											</svg>
										</div>
									</div>
									<div class="mt-2 sm:flex sm:justify-between">
										<div class="sm:flex space-x-6">
											<p class="flex items-center text-sm text-gray-500 dark:text-gray-400">
												<svg class="mr-1.5 h-4 w-4 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg"
														 viewBox="0 0 20 20" fill="currentColor">
													<path
													d="M10 8a3 3 0 100-6 3 3 0 000 6zM3.465 14.493a1.23 1.23 0 00.41 1.412A9.957 9.957 0 0010 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 00-13.074.003z" />
												</svg>
												@(issue.Author?.Name ?? "Unknown")
											</p>
										</div>
										<div class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-400 sm:mt-0">
											<svg class="mr-1.5 h-4 w-4 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg"
													 viewBox="0 0 20 20" fill="currentColor">
												<path fill-rule="evenodd"
															d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z"
															clip-rule="evenodd" />
											</svg>
											<time datetime="@issue.DateCreated.ToString("yyyy-MM-dd")">
												@issue.DateCreated.ToString("MMM d, yyyy")
											</time>
										</div>
									</div>
								</div>
							</a>
						</div>
					</li>
				}
			</ul>
		</div>

		<!-- Pagination -->
		<Pagination CurrentPage="@_currentPage" TotalPages="@_totalPages" TotalItems="@_totalItems"
								OnPageChange="OnPageChange" />
	}
</div>

<!-- Bulk Confirmation Modal -->
<BulkConfirmationModal @bind-IsVisible="_showConfirmationModal" Title="@_confirmationTitle"
											 Message="@_confirmationMessage" AffectedCount="@BulkSelectionState.SelectedCount"
											 ActionType="@_confirmationActionType" ConfirmButtonText="@_confirmationButtonText" IsProcessing="@_isProcessingBulk"
											 OnConfirm="ExecuteBulkOperation" OnCancel="CancelBulkOperation" />

<!-- Bulk Progress Indicator -->
<BulkProgressIndicator IsVisible="@_showProgressIndicator" Title="@_progressTitle" Progress="@_bulkProgress"
											 IsComplete="@_bulkOperationComplete" CanCancel="@(!_bulkOperationComplete)" OnCancel="CancelBulkOperation"
											 OnClosed="CloseProgressIndicator" />

<!-- Undo Toast -->
<UndoToast @bind-IsVisible="_showUndoToast" Message="@_undoMessage" UndoToken="@_lastUndoToken" OnUndo="HandleUndo"
					 OnDismissed="ClearUndoState" />

@code {

	private const string PageTitle = "Issues - IssueTracker";

	private IReadOnlyList<IssueDto>? _issues;
	private IEnumerable<StatusDto>? _statuses;
	private IEnumerable<CategoryDto>? _categories;

	private bool _isLoading = true;
	private string? _errorMessage;

	// Filter state
	private string? _searchText;
	private string? _statusFilter;
	private string? _categoryFilter;
	private DateOnly? _dateFrom;
	private DateOnly? _dateTo;

	// Pagination state
	private int _currentPage = 1;
	private int _totalPages = 1;
	private long _totalItems;
	private const int PAGE_SIZE = 10;

	// Bulk operation state
	private bool _isAdmin;
	private bool _sortByVotes;
	private bool _showConfirmationModal;
	private string _confirmationTitle = "";
	private string _confirmationMessage = "";
	private string _confirmationButtonText = "Confirm";
	private BulkConfirmationModal.BulkActionType _confirmationActionType;
	private bool _isProcessingBulk;
	private bool _showProgressIndicator;
	private string _progressTitle = "";
	private BulkOperationProgress? _bulkProgress;
	private bool _bulkOperationComplete;
	private bool _showUndoToast;
	private string _undoMessage = "";
	private string? _lastUndoToken;
	private CancellationTokenSource? _bulkOperationCts;

	// Pending bulk operation details
	private StatusDto? _pendingStatusChange;
	private CategoryDto? _pendingCategoryChange;
	private Func<Task>? _pendingBulkOperation;

	private bool HasActiveFilters =>
		!string.IsNullOrWhiteSpace(_searchText) ||
		!string.IsNullOrWhiteSpace(_statusFilter) ||
		!string.IsNullOrWhiteSpace(_categoryFilter) ||
		_dateFrom.HasValue ||
		_dateTo.HasValue;

	private IEnumerable<IssueDto> DisplayedIssues =>
		_sortByVotes
			? (_issues ?? []).Where(i => i.Votes > 0).OrderByDescending(i => i.Votes)
			: (_issues ?? []).AsEnumerable();

	protected override async Task OnInitializedAsync()
	{
		ParseQueryParameters();
		await LoadLookupsAsync();
		await LoadIssuesAsync();
		await CheckAdminStatus();

		// Subscribe to SignalR events for auto-refresh
		SignalRClient.OnIssueCreated += HandleIssueCreated;
		SignalRClient.OnIssueUpdated += HandleIssueUpdated;
		SignalRClient.OnIssueVoted += HandleIssueVoted;
	}

	private async Task CheckAdminStatus()
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_isAdmin = authState.User.IsInRole("Admin");
	}

	private void HandleIssueCreated(string issueId)
	{
		// Reload issues when a new issue is created
		InvokeAsync(async () =>
		{
			await LoadIssuesAsync();
			StateHasChanged();
		});
	}

	private void HandleIssueUpdated(string issueId)
	{
		// Reload issues when an issue is updated
		InvokeAsync(async () =>
		{
			await LoadIssuesAsync();
			StateHasChanged();
		});
	}

	private void HandleIssueVoted(string issueId)
	{
		// Reload issues when an issue receives or loses a vote
		InvokeAsync(async () =>
		{
			await LoadIssuesAsync();
			StateHasChanged();
		});
	}

	private void ParseQueryParameters()
	{
		var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
		var query = QueryHelpers.ParseQuery(uri.Query);

		if (query.TryGetValue("search", out var search))
		{
			_searchText = search.ToString();
		}

		if (query.TryGetValue("status", out var status))
		{
			_statusFilter = status.ToString();
		}

		if (query.TryGetValue("category", out var category))
		{
			_categoryFilter = category.ToString();
		}

		if (query.TryGetValue("from", out var from) && DateOnly.TryParse(from.ToString(), out var dateFrom))
		{
			_dateFrom = dateFrom;
		}

		if (query.TryGetValue("to", out var to) && DateOnly.TryParse(to.ToString(), out var dateTo))
		{
			_dateTo = dateTo;
		}

		if (query.TryGetValue("page", out var page) && int.TryParse(page.ToString(), out var pageNumber))
		{
			_currentPage = Math.Max(1, pageNumber);
		}
	}

	private void UpdateQueryParameters()
	{
		var queryParams = new Dictionary<string, string?>();

		if (!string.IsNullOrWhiteSpace(_searchText))
		{
			queryParams["search"] = _searchText;
		}

		if (!string.IsNullOrWhiteSpace(_statusFilter))
		{
			queryParams["status"] = _statusFilter;
		}

		if (!string.IsNullOrWhiteSpace(_categoryFilter))
		{
			queryParams["category"] = _categoryFilter;
		}

		if (_dateFrom.HasValue)
		{
			queryParams["from"] = _dateFrom.Value.ToString("yyyy-MM-dd");
		}

		if (_dateTo.HasValue)
		{
			queryParams["to"] = _dateTo.Value.ToString("yyyy-MM-dd");
		}

		if (_currentPage > 1)
		{
			queryParams["page"] = _currentPage.ToString();
		}

		var newUrl = QueryHelpers.AddQueryString("/issues", queryParams!);
		NavigationManager.NavigateTo(newUrl, forceLoad: false, replace: true);
	}

	private async Task LoadLookupsAsync()
	{
		var statusTask = LookupService.GetStatusesAsync();
		var categoryTask = LookupService.GetCategoriesAsync();

		await Task.WhenAll(statusTask, categoryTask);

		var statusResult = await statusTask;
		var categoryResult = await categoryTask;

		if (statusResult.Success)
		{
			_statuses = statusResult.Value;
		}

		if (categoryResult.Success)
		{
			_categories = categoryResult.Value;
		}
	}

	private async Task LoadIssuesAsync()
	{
		_isLoading = true;
		_errorMessage = null;

		try
		{
			var request = new IssueSearchRequest
			{
				SearchText = _searchText,
				StatusFilter = _statusFilter,
				CategoryFilter = _categoryFilter,
				DateFrom = _dateFrom,
				DateTo = _dateTo,
				Page = _currentPage,
				PageSize = PAGE_SIZE,
				IncludeArchived = false
			};

			var result = await IssueService.SearchIssuesAsync(request);

			if (result.Success && result.Value is not null)
			{
				_issues = result.Value.Items;
				_totalPages = result.Value.TotalPages;
				_totalItems = result.Value.TotalCount;
			}
			else
			{
				_errorMessage = result.Error ?? "Failed to load issues";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isLoading = false;
		}
	}

	private Task OnSearchTextChanged(string? value)
	{
		_searchText = value;
		return Task.CompletedTask;
	}

	private Task OnStatusFilterChanged(string? value)
	{
		_statusFilter = string.IsNullOrWhiteSpace(value) ? null : value;
		return Task.CompletedTask;
	}

	private Task OnCategoryFilterChanged(string? value)
	{
		_categoryFilter = string.IsNullOrWhiteSpace(value) ? null : value;
		return Task.CompletedTask;
	}

	private Task OnDateFromChanged(DateOnly? value)
	{
		_dateFrom = value;
		return Task.CompletedTask;
	}

	private Task OnDateToChanged(DateOnly? value)
	{
		_dateTo = value;
		return Task.CompletedTask;
	}

	private async Task OnFiltersApplied()
	{
		_currentPage = 1;
		UpdateQueryParameters();
		await LoadIssuesAsync();
	}

	private async Task OnFiltersCleared()
	{
		_searchText = null;
		_statusFilter = null;
		_categoryFilter = null;
		_dateFrom = null;
		_dateTo = null;
		_currentPage = 1;
		UpdateQueryParameters();
		await LoadIssuesAsync();
	}

	private async Task OnPageChange(int page)
	{
		_currentPage = page;
		UpdateQueryParameters();
		await LoadIssuesAsync();
	}

	private void ToggleTopVoted()
	{
		_sortByVotes = !_sortByVotes;
	}

	// Bulk operation handlers
	private void HandleBulkStatusChange(StatusDto status)
	{
		_pendingStatusChange = status;
		_pendingBulkOperation = ExecuteBulkStatusChange;
		_confirmationTitle = "Change Status";
		_confirmationMessage = $"Are you sure you want to change the status of the selected issues to '{status.StatusName}'?";
		_confirmationButtonText = "Change Status";
		_confirmationActionType = BulkConfirmationModal.BulkActionType.StatusChange;
		_showConfirmationModal = true;
	}

	private void HandleBulkCategoryChange(CategoryDto category)
	{
		_pendingCategoryChange = category;
		_pendingBulkOperation = ExecuteBulkCategoryChange;
		_confirmationTitle = "Change Category";
		_confirmationMessage = $"Are you sure you want to change the category of the selected issues to '{category.CategoryName}'?";
		_confirmationButtonText = "Change Category";
		_confirmationActionType = BulkConfirmationModal.BulkActionType.CategoryChange;
		_showConfirmationModal = true;
	}

	private void HandleBulkDelete()
	{
		_pendingBulkOperation = ExecuteBulkDelete;
		_confirmationTitle = "Delete Issues";
		_confirmationMessage = "Are you sure you want to delete the selected issues? This action cannot be undone.";
		_confirmationButtonText = "Delete";
		_confirmationActionType = BulkConfirmationModal.BulkActionType.Delete;
		_showConfirmationModal = true;
	}

	private async Task HandleBulkExport()
	{
		// Export selected issues to CSV
		var selectedIds = BulkSelectionState.SelectedIssueIds.ToList();
		if (selectedIds.Count == 0)
		{
			return;
		}

		// For now, show a toast indicating export feature
		ToastService.ShowInfo($"Exporting {selectedIds.Count} issues... (Feature coming soon)");
	}

	private async Task ExecuteBulkOperation()
	{
		if (_pendingBulkOperation is null)
		{
			return;
		}

		_isProcessingBulk = true;
		_showConfirmationModal = false;
		_showProgressIndicator = true;
		_bulkOperationComplete = false;
		_bulkOperationCts = new CancellationTokenSource();

		try
		{
			await _pendingBulkOperation();
		}
		finally
		{
			_isProcessingBulk = false;
			_pendingBulkOperation = null;
		}
	}

	private async Task ExecuteBulkStatusChange()
	{
		if (_pendingStatusChange is null)
		{
			return;
		}

		_progressTitle = $"Changing status to '{_pendingStatusChange.StatusName}'";
		var selectedIds = BulkSelectionState.SelectedIssueIds.ToList();

		var progress = new Progress<BulkOperationProgress>(p =>
		{
			_bulkProgress = p;
			InvokeAsync(StateHasChanged);
		});

		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var requestedBy = authState.User.FindFirst("sub")?.Value ?? "";

		var result = await BulkOperationService.BulkUpdateStatusAsync(
			selectedIds,
			_pendingStatusChange,
			requestedBy,
			progress,
			_bulkOperationCts?.Token ?? CancellationToken.None);

		await HandleBulkOperationComplete(result, "status changed");
		_pendingStatusChange = null;
	}

	private async Task ExecuteBulkCategoryChange()
	{
		if (_pendingCategoryChange is null)
		{
			return;
		}

		_progressTitle = $"Changing category to '{_pendingCategoryChange.CategoryName}'";
		var selectedIds = BulkSelectionState.SelectedIssueIds.ToList();

		var progress = new Progress<BulkOperationProgress>(p =>
		{
			_bulkProgress = p;
			InvokeAsync(StateHasChanged);
		});

		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var requestedBy = authState.User.FindFirst("sub")?.Value ?? "";

		var result = await BulkOperationService.BulkUpdateCategoryAsync(
			selectedIds,
			_pendingCategoryChange,
			requestedBy,
			progress,
			_bulkOperationCts?.Token ?? CancellationToken.None);

		await HandleBulkOperationComplete(result, "category changed");
		_pendingCategoryChange = null;
	}

	private async Task ExecuteBulkDelete()
	{
		_progressTitle = "Deleting issues";
		var selectedIds = BulkSelectionState.SelectedIssueIds.ToList();

		// Get current user for archive tracking
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var userId = authState.User.FindFirst("sub")?.Value ?? "";
		var userName = authState.User.Identity?.Name ?? "Unknown";
		var userEmail = authState.User.FindFirst("email")?.Value ?? "";
		var user = new UserDto(userId, userName, userEmail);

		var progress = new Progress<BulkOperationProgress>(p =>
		{
			_bulkProgress = p;
			InvokeAsync(StateHasChanged);
		});

		var result = await BulkOperationService.BulkDeleteAsync(
			selectedIds,
			user,
			userId,
			progress,
			_bulkOperationCts?.Token ?? CancellationToken.None);

		await HandleBulkOperationComplete(result, "deleted");
	}

	private async Task HandleBulkOperationComplete(Domain.Abstractions.Result<BulkOperationResult> result, string action)
	{
		_bulkOperationComplete = true;

		if (result.Success && result.Value is not null)
		{
			var opResult = result.Value;
			_undoMessage = $"{opResult.SuccessCount} issue(s) {action} successfully";
			_lastUndoToken = opResult.UndoToken;

			if (opResult.FailureCount > 0)
			{
				ToastService.ShowWarning($"{opResult.FailureCount} issue(s) failed to update");
			}
		}
		else
		{
			ToastService.ShowError(result.Error ?? "Bulk operation failed");
		}

		// Clear selection and reload
		BulkSelectionState.ClearSelection();
		await LoadIssuesAsync();
	}

	private void CancelBulkOperation()
	{
		_bulkOperationCts?.Cancel();
		_showConfirmationModal = false;
		_pendingBulkOperation = null;
		_pendingStatusChange = null;
		_pendingCategoryChange = null;
	}

	private void CloseProgressIndicator()
	{
		_showProgressIndicator = false;
		_bulkProgress = null;
		_bulkOperationComplete = false;

		// Show undo toast after closing progress
		if (!string.IsNullOrEmpty(_lastUndoToken))
		{
			_showUndoToast = true;
		}
	}

	private async Task HandleUndo(string undoToken)
	{
		var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var requestedBy = authState.User.FindFirst("sub")?.Value ?? "";
		var result = await BulkOperationService.UndoLastOperationAsync(undoToken, requestedBy);
		if (result.Success)
		{
			ToastService.ShowSuccess("Operation undone successfully");
			await LoadIssuesAsync();
		}
		else
		{
			ToastService.ShowError("Failed to undo operation");
		}
	}

	private void ClearUndoState()
	{
		_showUndoToast = false;
		_lastUndoToken = null;
		_undoMessage = "";
	}

	public async ValueTask DisposeAsync()
	{
		SignalRClient.OnIssueCreated -= HandleIssueCreated;
		SignalRClient.OnIssueUpdated -= HandleIssueUpdated;
		SignalRClient.OnIssueVoted -= HandleIssueVoted;
		_bulkOperationCts?.Cancel();
		_bulkOperationCts?.Dispose();
	}
}
