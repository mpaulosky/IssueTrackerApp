@page "/issues"
@using Microsoft.AspNetCore.Authorization
@using Web.Auth
@attribute [Authorize(Policy = AuthorizationPolicies.UserPolicy)]

<PageTitle>Issues</PageTitle>

<h1 class="text-3xl font-bold text-gray-900 mb-4">Issues</h1>

<p class="text-gray-600 mb-6">This page is accessible to authenticated users with the User role.</p>

<div class="bg-white rounded-lg shadow p-6">
	<h2 class="text-xl font-semibold text-gray-800 mb-4">Your Issues</h2>
	<p class="text-gray-500">Issue list will be displayed here.</p>
</div>
