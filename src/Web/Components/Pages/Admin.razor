@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Web.Auth
@attribute [Authorize(Policy = AuthorizationPolicies.AdminPolicy)]

<PageTitle>Admin Dashboard</PageTitle>

<h1 class="text-3xl font-bold text-gray-900 mb-4">Admin Dashboard</h1>

<p class="text-gray-600 mb-6">This page is only accessible to users with the Admin role.</p>

<div class="bg-white rounded-lg shadow p-6">
	<h2 class="text-xl font-semibold text-gray-800 mb-4">Admin Features</h2>
	<ul class="list-disc list-inside text-gray-600 space-y-2">
		<li>Manage users</li>
		<li>View all issues</li>
		<li>System configuration</li>
	</ul>
</div>
