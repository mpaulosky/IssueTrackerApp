@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<PageTitle>Home - IssueTracker</PageTitle>

<AuthorizeView>
	<Authorized>
		<div class="space-y-6">
			<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-8 border border-gray-200 dark:border-gray-700">
				<h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
					Welcome back, @context.User.Identity?.Name! 👋
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
					You're successfully logged in to IssueTracker. Use the navigation menu on the left to get started.
				</p>
				<div class="flex gap-4">
					<a href="/dashboard" class="px-6 py-3 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
						Go to Dashboard
					</a>
					<a href="/issues/create" class="px-6 py-3 bg-green-600 text-white font-medium rounded-md hover:bg-green-700 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
						Create New Issue
					</a>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center mb-4">
						<span class="text-3xl mr-3">📊</span>
						<h2 class="text-xl font-semibold text-gray-900 dark:text-white">Dashboard</h2>
					</div>
					<p class="text-gray-600 dark:text-gray-300 mb-4">
						View analytics, metrics, and insights about your issues.
					</p>
					<a href="/dashboard" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">
						View Dashboard →
					</a>
				</div>

				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center mb-4">
						<span class="text-3xl mr-3">📋</span>
						<h2 class="text-xl font-semibold text-gray-900 dark:text-white">Issues</h2>
					</div>
					<p class="text-gray-600 dark:text-gray-300 mb-4">
						Browse, search, and manage all your issues in one place.
					</p>
					<a href="/issues" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">
						View Issues →
					</a>
				</div>

				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6 border border-gray-200 dark:border-gray-700">
					<div class="flex items-center mb-4">
						<span class="text-3xl mr-3">➕</span>
						<h2 class="text-xl font-semibold text-gray-900 dark:text-white">Create</h2>
					</div>
					<p class="text-gray-600 dark:text-gray-300 mb-4">
						Report a new issue and start tracking it immediately.
					</p>
					<a href="/issues/create" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">
						Create Issue →
					</a>
				</div>
			</div>
		</div>
	</Authorized>
	<NotAuthorized>
		<div class="flex items-center justify-center min-h-[60vh]">
			<div class="max-w-2xl mx-auto text-center bg-white dark:bg-gray-800 rounded-lg shadow-xl p-12 border border-gray-200 dark:border-gray-700">
				<h1 class="text-5xl font-bold text-gray-900 dark:text-white mb-6">
					Welcome to IssueTracker 🎯
				</h1>
				<p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
					Manage, track, and resolve issues efficiently with our modern issue tracking system.
				</p>
				<div class="space-y-4 mb-8">
					<div class="flex items-center justify-center gap-3 text-gray-700 dark:text-gray-300">
						<span class="text-2xl">✅</span>
						<span class="text-lg">Track issues with rich details and categorization</span>
					</div>
					<div class="flex items-center justify-center gap-3 text-gray-700 dark:text-gray-300">
						<span class="text-2xl">📊</span>
						<span class="text-lg">View analytics and insights on your dashboard</span>
					</div>
					<div class="flex items-center justify-center gap-3 text-gray-700 dark:text-gray-300">
						<span class="text-2xl">🔄</span>
						<span class="text-lg">Real-time updates via SignalR</span>
					</div>
					<div class="flex items-center justify-center gap-3 text-gray-700 dark:text-gray-300">
						<span class="text-2xl">🎨</span>
						<span class="text-lg">Beautiful UI with dark mode support</span>
					</div>
				</div>
				<a href="/account/login?returnUrl=@Uri.EscapeDataString(Navigation.Uri)" 
					class="inline-block px-8 py-4 text-lg font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-lg">
					Log in to Get Started
				</a>
			</div>
		</div>
	</NotAuthorized>
</AuthorizeView>

