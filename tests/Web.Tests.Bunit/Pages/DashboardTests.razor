	[Fact]
	public async Task Dashboard_DisplaysAllFourStatCardHeadings()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(1, 1, 0, 1, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – all four card labels present
		cut.Markup.Should().Contain("Total Issues");
		cut.Markup.Should().Contain("Open Issues");
		cut.Markup.Should().Contain("Resolved Issues");
		cut.Markup.Should().Contain("This Week");
