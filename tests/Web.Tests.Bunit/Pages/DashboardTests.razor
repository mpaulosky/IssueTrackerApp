	// ──────────────────────────────────────────────────────────
	// Recent-issues list tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_DisplaysRecentIssueTitles()
	{
		// Arrange
		var issues = new List<IssueDto>
		{
			CreateTestIssue(title: "Login page crashes on Safari"),
			CreateTestIssue(title: "Dark mode flicker on reload"),
		};
		SetupDashboardService(new UserDashboardDto(2, 2, 0, 2, issues));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Login page crashes on Safari");
		cut.Markup.Should().Contain("Dark mode flicker on reload");
	}

	[Fact]
	public async Task Dashboard_RecentIssueLinksPointToCorrectDetailUrls()
	{
		// Arrange
		var issue = CreateTestIssue(title: "Linked Issue");
		var issues = new List<IssueDto> { issue };
		SetupDashboardService(new UserDashboardDto(1, 1, 0, 1, issues));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – there should be an anchor whose href contains /issues/{id}
		var issueLink = cut.FindAll("a")
			.FirstOrDefault(a => a.GetAttribute("href")?.Contains($"/issues/{issue.Id}") == true);

		issueLink.Should().NotBeNull(
			$"an anchor with href /issues/{issue.Id} should exist for recent issue '{issue.Title}'");
	}

	[Fact]
	public async Task Dashboard_RecentIssueListShowsFormattedDate()
	{
		// Arrange
		var knownDate = new DateTime(2024, 6, 15);
		var issue = CreateTestIssue() with { DateCreated = knownDate };
		SetupDashboardService(new UserDashboardDto(1, 1, 0, 1, new[] { issue }));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – component formats as "Jun 15, 2024"
		cut.Markup.Should().Contain("Jun 15, 2024",
			"each recent-issue row should show the creation date formatted as 'MMM d, yyyy'");
	}

	// ──────────────────────────────────────────────────────────
	// Empty-state tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_ShowsEmptyStateMessageWhenNoRecentIssues()
	{
		// Arrange – zero issues
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("No issues yet",
			"when the recent-issues list is empty the component should prompt the user");
		cut.Markup.Should().Contain("Create your first issue",
			"the empty state should include a call to action");
	}

	[Fact]
	public async Task Dashboard_EmptyStateSummaryCardPromptsCreation()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – summary card shows "haven't created any issues yet" text
		cut.Markup.Should().Contain(
			"You haven't created any issues yet",
			"the summary gradient card should encourage the user to create their first issue when counts are zero");
	}

	// ──────────────────────────────────────────────────────────
	// Error-state tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_ShowsErrorSectionWhenServiceReturnsFail()
	{
		// Arrange
		DashboardService
			.GetUserDashboardAsync(Arg.Any<string>(), Arg.Any<CancellationToken>())
			.Returns(Task.FromResult(Result.Fail<UserDashboardDto>("Service temporarily unavailable")));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Error loading dashboard");
		cut.Markup.Should().Contain("Service temporarily unavailable");
	}

	[Fact]
	public async Task Dashboard_ShowsExceptionMessageWhenServiceThrows()
	{
		// Arrange
		DashboardService
			.GetUserDashboardAsync(Arg.Any<string>(), Arg.Any<CancellationToken>())
			.Returns(Task.FromException<Result<UserDashboardDto>>(
				new InvalidOperationException("Database connection lost")));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Database connection lost",
			"unhandled exceptions should surface as the error message");
	}

	[Fact]
	public async Task Dashboard_ErrorStateDoesNotRenderStatCards()
	{
		// Arrange
		DashboardService
			.GetUserDashboardAsync(Arg.Any<string>(), Arg.Any<CancellationToken>())
			.Returns(Task.FromResult(Result.Fail<UserDashboardDto>("Oops")));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – stats section must not be rendered when there's an error
		cut.Markup.Should().NotContain("Total Issues",
			"stat cards should not appear when the service has returned an error");
	}

	// ──────────────────────────────────────────────────────────
	// Welcome / user-identity tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_DisplaysWelcomeBackWithAuthenticatedUserName()
	{
		// Arrange
		SetupAuthenticatedUser(userId: "u1", userName: "Alice Wonderland");
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Welcome back");
		cut.Markup.Should().Contain("Alice Wonderland");
	}

	[Fact]
	public async Task Dashboard_DisplaysAuthenticatedUserName()
	{
		// Verifies that the welcome section shows the signed-in user's display name.
		// (The fallback path "User" cannot be exercised through BunitTestBase alone
		// because SetupAuthenticatedUser always provides identity name claims.)
		// Arrange
		SetupAuthenticatedUser(userId: "u2", userName: "Bob Builder");
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – name appears in welcome section
		cut.Markup.Should().Contain("Bob Builder");
	}

	// ──────────────────────────────────────────────────────────
	// Quick-actions tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_QuickActionsContainsCreateNewIssueLink()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		var createLink = cut.FindAll("a")
			.FirstOrDefault(a => a.GetAttribute("href") == "/issues/create");

		createLink.Should().NotBeNull("a 'Create New Issue' link should always appear in Quick Actions");
		createLink!.TextContent.Should().Contain("Create New Issue");
	}

