	}

	[Fact]
	public async Task Dashboard_DisplaysCorrectThisWeekCount()
	{
		// Arrange – use 205 as sentinel
		SetupDashboardService(new UserDashboardDto(500, 100, 200, 205, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("This Week");
		cut.Markup.Should().Contain("205",
			"ThisWeekIssues value should be rendered in the stats card");
