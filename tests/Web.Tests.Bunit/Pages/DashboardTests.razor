@inherits Web.Tests.Bunit.BunitTestBase

@code {

	// ──────────────────────────────────────────────────────────
	// Loading-state tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public void Dashboard_ShowsLoadingSpinnerWhileDataIsPending()
	{
		// Arrange – never resolve the task so the component stays in _isLoading = true
		var tcs = new TaskCompletionSource<Result<UserDashboardDto>>();
		DashboardService
			.GetUserDashboardAsync(Arg.Any<string>(), Arg.Any<CancellationToken>())
			.Returns(tcs.Task);

		// Act
		var cut = Render<Dashboard>();

		// Assert – spinner SVG is present
		cut.Markup.Should().Contain("animate-spin",
			"a loading spinner should be visible before data arrives");
	}

	[Fact]
	public async Task Dashboard_HidesLoadingSpinnerAfterDataLoads()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(3, 1, 2, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().NotContain("animate-spin",
			"the spinner should disappear once data has loaded");
	}

	// ──────────────────────────────────────────────────────────
	// Stats-count tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_DisplaysCorrectTotalIssuesCount()
	{
		// Arrange – use a large distinctive value (142) that won't accidentally
		// appear in SVG path data rendered by the component.
		SetupDashboardService(new UserDashboardDto(142, 107, 130, 15, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – label and distinctive number must both be present
		cut.Markup.Should().Contain("Total Issues");
		cut.Markup.Should().Contain("142",
			"TotalIssues value should be rendered in the stats card");
	}

	[Fact]
	public async Task Dashboard_DisplaysCorrectOpenIssuesCount()
	{
		// Arrange – use 107 which will not appear in any SVG path attribute
		SetupDashboardService(new UserDashboardDto(200, 107, 80, 13, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Open Issues");
		cut.Markup.Should().Contain("107",
			"OpenIssues value should be rendered in the stats card");
	}

	[Fact]
	public async Task Dashboard_DisplaysCorrectResolvedIssuesCount()
	{
		// Arrange – use 311 as a three-digit sentinel
		SetupDashboardService(new UserDashboardDto(400, 89, 311, 3, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("Resolved Issues");
		cut.Markup.Should().Contain("311",
