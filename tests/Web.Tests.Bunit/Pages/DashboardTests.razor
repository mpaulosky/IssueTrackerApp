	[Fact]
	public async Task Dashboard_NonAdminUserDoesNotSeeAdminDashboardLink()
	{
		// Arrange – regular authenticated user (default from BunitTestBase)
		SetupAuthenticatedUser(userId: "user1", userName: "Regular User", isAdmin: false);
		SetupDashboardService(new UserDashboardDto(0, 0, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		var adminLink = cut.FindAll("a")
			.FirstOrDefault(a => a.GetAttribute("href") == "/admin");

		adminLink.Should().BeNull("non-admin users must NOT see the Admin Dashboard link");
	}

	// ──────────────────────────────────────────────────────────
	// Summary-card / Issue-summary tests
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_SummaryCardShowsOpenIssueCountAndPercentage()
	{
		// Arrange – 100 total, 40 open → exactly 40 %; use sentinel 100/40 values
		// that won't appear in SVG path data.
		SetupDashboardService(new UserDashboardDto(100, 40, 60, 2, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – summary card text should mention "40" open issues and "40%"
		cut.Markup.Should().Contain("Issue Summary");
		cut.Markup.Should().Contain("40",
			"the open-issue count should be bold inside the summary card");
		cut.Markup.Should().Contain("40%",
			"the percentage of open issues should be calculated and rendered");
	}

	[Fact]
	public async Task Dashboard_SummaryCardShowsThisWeekIssuesParagraph()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(8, 3, 5, 3, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().Contain("issue(s) created this week",
			"when ThisWeekIssues > 0 the summary card should mention them");
	}

	[Fact]
	public async Task Dashboard_SummaryCardOmitsThisWeekParagraphWhenZero()
	{
		// Arrange
		SetupDashboardService(new UserDashboardDto(5, 2, 3, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert
		cut.Markup.Should().NotContain("issue(s) created this week",
			"the 'this week' paragraph must be suppressed when count is 0");
	}

	// ──────────────────────────────────────────────────────────
	// View-All link for recent issues
	// ──────────────────────────────────────────────────────────

	[Fact]
	public async Task Dashboard_ViewAllLinkContainsAuthenticatedUserId()
	{
		// Arrange
		SetupAuthenticatedUser(userId: "uid-xyz");
		SetupDashboardService(new UserDashboardDto(5, 5, 0, 0, []));

		// Act
		var cut = Render<Dashboard>();
		await cut.InvokeAsync(() => Task.Delay(100));

		// Assert – "View All →" link should include the user's ID as the author filter
		var viewAllLink = cut.FindAll("a")
			.FirstOrDefault(a => a.GetAttribute("href")?.Contains("author=uid-xyz") == true);

		viewAllLink.Should().NotBeNull(
			"the 'View All →' anchor in My Recent Issues must include ?author={userId}");
	}

	// ──────────────────────────────────────────────────────────
	// Helpers
	// ──────────────────────────────────────────────────────────

	/// <summary>
	/// Configures <see cref="IDashboardService"/> to return a successful result
	/// for any user ID.
	/// </summary>
	private void SetupDashboardService(UserDashboardDto dto)
	{
		DashboardService
			.GetUserDashboardAsync(Arg.Any<string>(), Arg.Any<CancellationToken>())
			.Returns(Task.FromResult(Result.Ok(dto)));
	}
}
